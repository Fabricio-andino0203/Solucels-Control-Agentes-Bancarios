<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Configuración - Solucels Control Agentes Bancarios</title>
    <style>
        :root {
            --glass-bg: rgba(25, 25, 25, 0.7);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        .config-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
            padding: 1.5rem;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            backdrop-filter: blur(10px);
        }

        .section-title {
            font-size: 1.3rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .grid-config {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
        }

        .card-premium {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 1.75rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .card-premium:hover {
            transform: translateY(-5px);
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }

        /* BANCO CARDS SPECIFIC */
        .bank-chip {
            display: inline-flex;
            align-items: center;
            padding: 0.4rem 1rem;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 1.25rem;
            text-transform: uppercase;
        }

        .input-group-premium {
            margin-bottom: 1.25rem;
        }

        .input-group-premium label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-premium {
            width: 100%;
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--glass-border);
            border-radius: 14px;
            padding: 0.8rem 1rem;
            color: #fff;
            font-size: 1.1rem;
            font-weight: 600;
            transition: all 0.2s;
        }

        .input-premium:focus {
            outline: none;
            border-color: var(--accent-blue);
            background: rgba(0,0,0,0.4);
            box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.1);
        }

        .btn-premium {
            width: 100%;
            padding: 0.9rem;
            border-radius: 14px;
            border: none;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .rule-card {
            border-left: 4px solid var(--accent-blue);
        }

        .danger-zone {
            margin-top: 5rem;
            padding: 2.5rem;
            background: rgba(227, 0, 15, 0.03);
            border: 1px dashed rgba(227, 0, 15, 0.2);
            border-radius: 24px;
            text-align: center;
        }

        .btn-danger-premium {
            background: rgba(227, 0, 15, 0.1);
            color: #ff453a;
            border: 1px solid rgba(227, 0, 15, 0.3);
            padding: 1rem 2rem;
            border-radius: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-danger-premium:hover {
            background: #e3000f;
            color: #fff;
            box-shadow: 0 5px 20px rgba(227, 0, 15, 0.4);
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { active: 'configuracion', user: user }) %>
    <main class="main-content">
        <div class="config-header">
            <div>
                <h1 style="font-size: 1.8rem; font-weight: 900; margin: 0;">Panel de Configuración</h1>
                <p style="color: var(--text-muted); margin: 0.2rem 0 0 0; font-size: 0.9rem;">Gestión de saldos operativos y reglas de negocio.</p>
            </div>
            <% if(user && user.rol === 'Admin') { %>
                <a href="/config/iniciales" class="btn btn-primary" style="text-decoration: none; border-radius: 12px; padding: 0.8rem 1.5rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                    ⚙️ Saldos por Tienda
                </a>
            <% } %>
        </div>

        <div class="section-title">
            <span>🏦</span> Saldos Iniciales Centrales
        </div>
        
        <div class="grid-config" style="margin-bottom: 4rem;">
            <% saldos.forEach(b => { %>
                <div class="card-premium">
                    <div class="bank-chip" style="background: <%= b.color %>15; color: <%= b.color %>; border: 1px solid <%= b.color %>30;">
                        <%= b.nombre %>
                    </div>
                    
                    <form action="/config/saldos" method="POST">
                        <input type="hidden" name="banco_id" value="<%= b.id %>">
                        
                        <!-- Mostramos el saldo actual como información de lectura -->
                        <div class="input-group-premium" style="opacity: 0.8;">
                            <label>Saldo Virtual Actual (En Línea)</label>
                            <div class="input-premium" style="background: rgba(255,255,255,0.05); color: var(--accent-blue);">
                                L <%= (b.saldo || 0).toLocaleString('es-HN', {minimumFractionDigits: 2}) %>
                            </div>
                        </div>

                        <div class="input-group-premium">
                            <label>Saldo Inicial en Cuenta</label>
                            <input type="text" name="saldo_inicial" class="input-premium money-input" value="<%= (b.saldo_inicial || 0).toFixed(2) %>" required>
                            <small style="color: var(--text-muted); font-size: 0.7rem; display: block; mt-1;">Cambiar este valor ajustará el saldo actual automáticamente.</small>
                        </div>
                        
                        <% if(user && user.rol === 'Admin') { %>
                            <button type="submit" class="btn-premium" style="background: <%= b.color %>; color: #fff;">
                                💾 Ajustar Monto Inicial
                            </button>
                        <% } else { %>
                            <button type="button" class="btn-premium" style="background: rgba(255,255,255,0.05); color: var(--text-muted); cursor: not-allowed;" disabled>
                                🔒 Solo Lectura
                            </button>
                        <% } %>
                    </form>
                </div>
            <% }) %>
        </div>

        <div class="section-title">
            <span>⚡</span> Reglas de Comisión Automática
        </div>
        
        <div class="grid-config">
            <% comisiones.forEach(c => { %>
                <div class="card-premium rule-card" style="border-left-color: <%= c.banco_color %>;">
                    <div style="font-size: 0.9rem; font-weight: 800; color: <%= c.banco_color %>; margin-bottom: 0.2rem; text-transform: uppercase;">
                        <%= c.tipo_transaccion %>
                    </div>
                    <div style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1.5rem; opacity: 0.9;">
                        <%= c.banco_nombre %>
                    </div>

                    <form action="/config/comisiones" method="POST">
                        <input type="hidden" name="comision_id" value="<%= c.id %>">
                        <div class="input-group-premium">
                            <label>📥 Suma a Efectivo Físico</label>
                            <input type="text" name="valor_efectivo" class="input-premium money-input" value="<%= c.valor_efectivo %>" required>
                        </div>
                        <div class="input-group-premium">
                            <label>🏦 Suma a Saldo Virtual</label>
                            <input type="text" name="valor_virtual" class="input-premium money-input" value="<%= c.valor_virtual %>" required>
                        </div>
                        
                        <% if(user && user.rol === 'Admin') { %>
                            <button type="submit" class="btn-premium" style="background: var(--accent-blue); color: #fff;">
                                🛡️ Guardar Regla
                            </button>
                        <% } else { %>
                            <button type="button" class="btn-premium" style="background: rgba(255,255,255,0.05); color: var(--text-muted); cursor: not-allowed;" disabled>
                                🔒 Solo Lectura
                            </button>
                        <% } %>
                    </form>
                </div>
            <% }) %>
        </div>

        <% if(user && user.rol === 'Admin') { %>
        <div class="danger-zone">
            <h3 style="color: #ff453a; font-weight: 900; margin-bottom: 0.5rem;">Zona de Peligro</h3>
            <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem;">¿Necesitas reiniciar el sistema para un nuevo mes o auditoría? Esto borrará todas las transacciones históricas.</p>
            <form action="/config/reset" method="POST" id="resetForm">
                <button type="button" class="btn-danger-premium" onclick="confirmReset()">
                    🗑️ BORRAR BASE DE DATOS DEFINITIVAMENTE
                </button>
            </form>
        </div>
        <% } %>
    </main>

    <script>
        function confirmReset() {
            if(confirm("⚠ ADVERTENCIA CRÍTICA ⚠\n¿Estás absolutamente seguro? Se perderán todas las transacciones y los saldos volverán a cero.")) {
                if(confirm("Doble confirmación: Esta acción es irreversible.")) {
                    document.getElementById('resetForm').submit();
                }
            }
        }
    </script>
    <script src="/js/money-formatter.js"></script>
</body>
</html>
