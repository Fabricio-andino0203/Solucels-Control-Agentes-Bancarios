<!DOCTYPE html>
<html lang="es">
<head>
    <title>Tesorería Central - Solucels Control</title>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/tesoreria.css">
</head>
<body>
    <%- include('partials/sidebar', { active: 'tesoreria', user: user }) %>
    
    <main class="main-content">
        <header class="header">
            <div>
                <h1>🪙 Tesorería Central</h1>
                <p style="color: var(--text-muted); font-size: 0.9rem;">Gestión modular de efectivo y bancos</p>
            </div>
            <div class="user-profile">
                <div style="text-align: right; margin-right: 1rem;">
                    <div style="font-weight: 700;"><%= user.username %></div>
                    <div style="font-size: 0.75rem; color: var(--accent-blue);"><%= user.rol %></div>
                </div>
                <div class="avatar-mini" style="background: var(--accent-blue); width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 900; color: #fff;">
                    <%= user.username.substring(0,2).toUpperCase() %>
                </div>
            </div>
        </header>

        <div class="tesoreria-container">
            <!-- Sidebar Navegación Modular -->
            <nav class="tesoreria-nav">
                <button class="nav-module-btn active" data-module="dashboard" onclick="showModule('dashboard')">
                    <span class="icon">📊</span> Dashboard
                </button>
                <button class="nav-module-btn" data-module="recepciones" onclick="showModule('recepciones')">
                    <span class="icon">📥</span> Recepciones 
                    <% if(remesasPendientes.length > 0) { %>
                        <span style="background: var(--danger); font-size: 0.6rem; padding: 2px 6px; border-radius: 10px; margin-left: auto;"><%= remesasPendientes.length %></span>
                    <% } %>
                </button>
                <button class="nav-module-btn" data-module="operaciones" onclick="showModule('operaciones')">
                    <span class="icon">⚙️</span> Operaciones
                </button>
                <button class="nav-module-btn" data-module="auditoria" onclick="showModule('auditoria')">
                    <span class="icon">📜</span> Auditoría
                </button>
                <% if(user.rol === 'Admin' || user.rol === 'Contador') { %>
                    <button class="nav-module-btn" data-module="cierre" onclick="showModule('cierre')">
                        <span class="icon">🏁</span> Corte Diario
                    </button>
                <% } %>
            </nav>

            <!-- Área de Contenido Modular -->
            <div class="tesoreria-content">
                <%- include('tesoreria/dashboard_mod') %>
                <%- include('tesoreria/recepciones_mod') %>
                <%- include('tesoreria/operaciones_mod') %>
                <%- include('tesoreria/auditoria_mod') %>
                <%- include('tesoreria/cierre_mod') %>
            </div>
        </div>
    </main>

    <script src="/js/money-formatter.js"></script>
    <script>
        function showModule(moduleId) {
            // Ocultar todos los módulos
            document.querySelectorAll('.tesoreria-module').forEach(m => m.style.display = 'none');
            // Quitar active de botones
            document.querySelectorAll('.nav-module-btn').forEach(b => b.classList.remove('active'));
            
            // Mostrar seleccionado
            document.getElementById('module-' + moduleId).style.display = 'block';
            // Marcar botón active
            document.querySelector(`[data-module="${moduleId}"]`).classList.add('active');
            
            // Guardar en URL sin recargar
            const url = new URL(window.location);
            url.searchParams.set('module', moduleId);
            window.history.pushState({}, '', url);
        }

        // Cargar módulo desde URL al iniciar
        window.addEventListener('load', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const initialModule = urlParams.get('module') || 'dashboard';
            showModule(initialModule);
        });

        // Formateo de inputs de dinero
        document.querySelectorAll('.money-input-premium').forEach(input => {
            input.addEventListener('input', function(e) {
                let value = e.target.value.replace(/[^0-9.]/g, '');
                if (value) {
                    // Solo permitir un punto decimal
                    let parts = value.split('.');
                    if (parts.length > 2) value = parts[0] + '.' + parts.slice(1).join('');
                }
                e.target.value = value;
            });
            
            input.addEventListener('blur', function(e) {
                let value = parseFloat(e.target.value);
                if (!isNaN(value)) {
                    e.target.value = value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }
            });

            input.addEventListener('focus', function(e) {
                e.target.value = e.target.value.replace(/,/g, '');
            });
        });
    </script>
</body>
</html>
