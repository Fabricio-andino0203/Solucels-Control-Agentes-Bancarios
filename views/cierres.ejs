<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Cierres de Caja - Solucels Control</title>
    <!-- jsPDF nativo (no html2pdf) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        /* ====== LAYOUT ====== */
        .cierres-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .cierres-title { font-size: 1.5rem; font-weight: 900; color: #fff; }
        .cierres-subtitle { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.2rem; }

        /* ====== FILTROS ====== */
        .filter-bar {
            display: flex;
            gap: 0.75rem;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
            padding: 0.9rem 1.1rem;
            background: var(--bg-card);
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .filter-bar label { font-size: 0.78rem; color: var(--text-muted); font-weight: 600; }
        .filter-bar select, .filter-bar input[type="date"] {
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 8px;
            color: #fff;
            padding: 0.4rem 0.75rem;
            font-size: 0.85rem;
        }

        /* ====== CIERRE CARD ====== */
        .cierre-card {
            background: var(--bg-card);
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.07);
            margin-bottom: 1.25rem;
            overflow: hidden;
            transition: border-color 0.2s;
        }
        .cierre-card:hover { border-color: rgba(10,132,255,0.3); }

        .cierre-card-header {
            display: grid;
            grid-template-columns: auto 1fr auto auto;
            align-items: center;
            gap: 1.25rem;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            cursor: pointer;
            user-select: none;
        }
        .cierre-card-header:hover { background: rgba(255,255,255,0.02); }

        .cierre-badge {
            width: 40px; height: 40px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            background: rgba(10,132,255,0.12);
            border: 1px solid rgba(10,132,255,0.25);
            flex-shrink: 0;
        }
        .cierre-info { min-width: 0; }
        .cierre-tienda { font-weight: 800; font-size: 0.95rem; color: #fff; }
        .cierre-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem; }

        .cierre-dif-badge {
            padding: 0.3rem 0.75rem;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 700;
            white-space: nowrap;
        }
        .dif-ok { background: rgba(52,199,89,0.12); color: #34C759; border: 1px solid rgba(52,199,89,0.3); }
        .dif-falta { background: rgba(255,69,58,0.12); color: #FF453A; border: 1px solid rgba(255,69,58,0.3); }
        .dif-sobra { background: rgba(255,159,10,0.12); color: #FF9F0A; border: 1px solid rgba(255,159,10,0.3); }

        .cierre-chevron {
            font-size: 0.85rem;
            color: var(--text-muted);
            transition: transform 0.3s;
            flex-shrink: 0;
        }
        .cierre-card.expanded .cierre-chevron { transform: rotate(180deg); }

        /* ====== DETALLE ====== */
        .cierre-detail {
            display: none;
            padding: 0;
            animation: fadeIn 0.2s ease;
        }
        .cierre-card.expanded .cierre-detail { display: block; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .detail-stat {
            padding: 1rem 1.25rem;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .detail-stat:last-child { border-right: none; }
        .detail-stat-label {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 0.3rem;
        }
        .detail-stat-value {
            font-size: 1.1rem;
            font-weight: 900;
            color: #fff;
        }

        .detail-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }
        @media(max-width: 768px) { .detail-body { grid-template-columns: 1fr; } }

        .detail-section {
            padding: 1.1rem 1.25rem;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .detail-section:last-child { border-right: none; }
        .detail-section-title {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .line-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.4rem 0;
            font-size: 0.85rem;
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }
        .line-item:last-child { border-bottom: none; }
        .line-label { color: var(--text-muted); }
        .line-value { font-weight: 700; color: #fff; }
        .line-value.green { color: #34C759; }
        .line-value.red { color: #FF453A; }
        .line-value.orange { color: #FF9F0A; }
        .line-value.blue { color: var(--accent-blue); }
        .line-value.purple { color: #AF52DE; }

        .bank-dot-sm { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 5px; flex-shrink: 0; }

        .cierre-actions {
            padding: 0.85rem 1.25rem;
            background: rgba(0,0,0,0.15);
            border-top: 1px solid rgba(255,255,255,0.04);
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }

        .btn-pdf-card {
            background: rgba(255,59,48,0.12);
            border: 1px solid rgba(255,59,48,0.3);
            color: #FF453A;
            padding: 0.45rem 1rem;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.82rem;
            font-weight: 700;
            transition: all 0.2s;
        }
        .btn-pdf-card:hover { background: rgba(255,59,48,0.25); }

        .btn-revert {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: var(--text-muted);
            padding: 0.45rem 1rem;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.82rem;
            font-weight: 700;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-revert:hover { background: rgba(255,69,58,0.1); color: #FF453A; border-color: rgba(255,69,58,0.3); }

        /* ====== EMPTY ====== */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--text-muted);
        }
        .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }

        /* ====== TOP SUMMARY ====== */
        .summary-strip {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }
        .summary-chip {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px;
            padding: 0.85rem 1.1rem;
        }
        .summary-chip-label { font-size: 0.7rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }
        .summary-chip-value { font-size: 1.2rem; font-weight: 900; margin-top: 0.2rem; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { active: 'cierres', user: user }) %>
    <main class="main-content">

        <!-- HEADER -->
        <div class="header">
            <div>
                <div class="cierres-title">📋 Registro de Cierres</div>
                <div class="cierres-subtitle">Historial completo de cierres de caja por tienda</div>
            </div>
            <div style="display:flex; gap:0.75rem; align-items:center;">
                <span style="font-size:0.85rem; color:var(--text-muted);"><%= user.username %> (<%= user.rol %>)</span>
                <a href="/logout" style="color:#FF453A; font-size:0.85rem;">Salir</a>
            </div>
        </div>

        <% 
        // Calcular totales globales
        const totalGlobalOps = cierres.reduce((a,c) => a + (c.resumen ? c.resumen.total_ops : 0), 0);
        const totalGlobalDep = cierres.reduce((a,c) => a + (c.resumen ? c.resumen.depositos : 0), 0);
        const totalGlobalRet = cierres.reduce((a,c) => a + (c.resumen ? c.resumen.retiros : 0), 0);
        const totalGlobalEntreg = cierres.reduce((a,c) => a + (c.totalEntregado || 0), 0);
        %>

        <% if(cierres.length > 0) { %>
        <!-- RESUMEN GLOBAL -->
        <div class="summary-strip">
            <div class="summary-chip">
                <div class="summary-chip-label">Total Cierres</div>
                <div class="summary-chip-value" style="color:#fff;"><%= cierres.length %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Depósitos</div>
                <div class="summary-chip-value" style="color:#34C759;">L <%= totalGlobalDep.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Retiros</div>
                <div class="summary-chip-value" style="color:#FF453A;">L <%= totalGlobalRet.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Entregado</div>
                <div class="summary-chip-value" style="color:#AF52DE;">L <%= totalGlobalEntreg.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Operaciones</div>
                <div class="summary-chip-value" style="color:var(--accent-blue);"><%= totalGlobalOps %></div>
            </div>
        </div>
        <% } %>

        <!-- LISTA DE CIERRES -->
        <% if(cierres.length === 0) { %>
        <div class="empty-state">
            <div class="icon">📭</div>
            <div style="font-size:1.1rem; font-weight:700; margin-bottom:0.5rem;">No hay cierres registrados</div>
            <div style="font-size:0.85rem;">Los cierres se registran desde el POS al finalizar el turno.</div>
        </div>
        <% } else { %>

        <% cierres.forEach((c, idx) => { 
            const dif = c.diferencia || 0;
            const difClass = Math.abs(dif) < 0.01 ? 'dif-ok' : (dif < 0 ? 'dif-falta' : 'dif-sobra');
            const difLabel = Math.abs(dif) < 0.01 ? '✓ CUADRA' : (dif < 0 ? '▼ FALTA L ' + Math.abs(dif).toFixed(2) : '▲ SOBRA L ' + dif.toFixed(2));
            const r = c.resumen || {};
            const totalDeclarado = c.saldo_real || 0;
            const quedaMañana = Math.max(0, totalDeclarado - (c.totalEntregado || 0));
        %>
        <div class="cierre-card" id="card-<%= idx %>">

            <!-- HEADER TARJETA (clickeable para expandir) -->
            <div class="cierre-card-header" onclick="toggleCard(<%= idx %>)">
                <div class="cierre-badge">🔒</div>
                <div class="cierre-info">
                    <div class="cierre-tienda"><%= c.tienda_nombre %></div>
                    <div class="cierre-meta">
                        <%= new Date(c.fecha).toLocaleString('es-HN', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                        &nbsp;·&nbsp; Cajero: <strong><%= c.username %></strong>
                        &nbsp;·&nbsp; <%= (r.total_ops || 0) %> operaciones
                    </div>
                </div>
                <div class="cierre-dif-badge <%= difClass %>"><%= difLabel %></div>
                <div class="cierre-chevron">▼</div>
            </div>

            <!-- DETALLE EXPANDIBLE -->
            <div class="cierre-detail">

                <!-- FILA DE MÉTRICAS CLAVE -->
                <div class="detail-grid">
                    <div class="detail-stat">
                        <div class="detail-stat-label">💰 Total Movido (Entrada Ef.)</div>
                        <div class="detail-stat-value" style="color:#34C759;">L <%= (c.totalMovido||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">📤 Depósitos a Banco</div>
                        <div class="detail-stat-value" style="color:#FF9F0A;">L <%= (r.deposito_cuenta||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">💸 Efectivo Entregado</div>
                        <div class="detail-stat-value" style="color:#AF52DE;">L <%= (c.totalEntregado||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">🌅 Queda para Mañana</div>
                        <div class="detail-stat-value" style="color:var(--accent-blue);">L <%= quedaMañana.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">📊 Real Declarado</div>
                        <div class="detail-stat-value">L <%= (c.saldo_real||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">🧮 Teórico del Sistema</div>
                        <div class="detail-stat-value" style="color:var(--text-muted);">L <%= (c.saldo_teorico||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                </div>

                <!-- CUERPO PRINCIPAL: 2 COLUMNAS -->
                <div class="detail-body">

                    <!-- COLUMNA 1: Resumen de operaciones por tipo -->
                    <div class="detail-section">
                        <div class="detail-section-title">📈 Operaciones del Turno</div>

                        <% if((r.depositos||0) > 0) { %>
                        <div class="line-item">
                            <span class="line-label">📥 Depósitos recibidos</span>
                            <span class="line-value green">+ L <%= r.depositos.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <% if((r.retiros||0) > 0) { %>
                        <div class="line-item">
                            <span class="line-label">📤 Retiros</span>
                            <span class="line-value red">- L <%= r.retiros.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <% if((r.pagos_servicio||0) > 0) { %>
                        <div class="line-item">
                            <span class="line-label">🧾 Pagos de Servicio</span>
                            <span class="line-value green">+ L <%= r.pagos_servicio.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <% if((r.caja_empresarial||0) > 0) { %>
                        <div class="line-item">
                            <span class="line-label">🏢 Caja Empresarial</span>
                            <span class="line-value green">+ L <%= r.caja_empresarial.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <% if((r.deposito_cuenta||0) > 0) { %>
                        <div class="line-item">
                            <span class="line-label">🏦 Depósitos a Cuenta</span>
                            <span class="line-value orange">- L <%= r.deposito_cuenta.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <% if((r.efectivo_entregado||0) > 0) { %>
                        <div class="line-item">
                            <span class="line-label">💰 Efectivo en Tránsito</span>
                            <span class="line-value purple">- L <%= r.efectivo_entregado.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <% if((r.total_ops||0) === 0) { %>
                        <div style="color:var(--text-muted); font-size:0.82rem; padding: 0.5rem 0;">Sin operaciones en este turno</div>
                        <% } %>

                        <!-- Salida total tesorería -->
                        <% if((c.totalEntregado||0) > 0) { %>
                        <div class="line-item" style="margin-top:0.5rem; padding-top:0.5rem; border-top: 1px solid rgba(175,82,222,0.2);">
                            <span class="line-label" style="font-weight:700;">Total entregado al Contador</span>
                            <span class="line-value purple">L <%= (c.totalEntregado||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>

                        <!-- Saldo final -->
                        <div class="line-item" style="margin-top:0.5rem; padding-top:0.5rem; border-top: 1px solid rgba(52,199,89,0.25); font-size:0.9rem;">
                            <span style="color:#34C759; font-weight:800;">🌅 Queda para mañana</span>
                            <span class="line-value" style="color:#34C759; font-size:1rem;">L <%= quedaMañana.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                    </div>

                    <!-- COLUMNA 2: Desglose por banco -->
                    <div class="detail-section">
                        <div class="detail-section-title">🏦 Desglose por Banco</div>

                        <% if(c.txBancos && c.txBancos.length > 0) { %>
                        <% c.txBancos.forEach(b => { %>
                        <div style="margin-bottom: 0.75rem; padding: 0.6rem 0.8rem; border-radius: 8px; background: rgba(255,255,255,0.02); border-left: 3px solid <%= b.banco_color || '#555' %>;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.3rem;">
                                <span style="color:<%= b.banco_color||'#aaa' %>; font-weight:700; font-size:0.85rem;">
                                    <span class="bank-dot-sm" style="background:<%= b.banco_color||'#555' %>;"></span>
                                    <%= b.banco_nombre %>
                                </span>
                                <span style="font-size:0.75rem; color:var(--text-muted);"><%= b.ops %> ops</span>
                            </div>
                            <% if((b.entrada_ef||0) > 0) { %>
                            <div class="line-item" style="padding:0.2rem 0;">
                                <span class="line-label" style="font-size:0.78rem;">Entrada efectivo</span>
                                <span class="line-value green" style="font-size:0.82rem;">+ L <%= (b.entrada_ef||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                            </div>
                            <% } %>
                            <% if((b.salida_ef||0) > 0) { %>
                            <div class="line-item" style="padding:0.2rem 0;">
                                <span class="line-label" style="font-size:0.78rem;">Salida efectivo</span>
                                <span class="line-value red" style="font-size:0.82rem;">- L <%= (b.salida_ef||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                            </div>
                            <% } %>
                            <div class="line-item" style="padding:0.2rem 0;">
                                <span class="line-label" style="font-size:0.78rem; font-weight:700;">Neto efectivo</span>
                                <span class="line-value" style="font-size:0.85rem; color:<%= (b.neto_ef||0) >= 0 ? '#34C759' : '#FF453A' %>;">
                                    L <%= (b.neto_ef||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %>
                                </span>
                            </div>
                        </div>
                        <% }); %>
                        <% } else { %>
                        <div style="color:var(--text-muted); font-size:0.82rem; padding: 0.5rem 0;">Sin transacciones por banco en este turno</div>
                        <% } %>

                        <!-- Entrega por banco si existe -->
                        <% const entregaKeys = Object.keys(c.entregaPorBanco || {}); %>
                        <% if(entregaKeys.length > 0) { %>
                        <div class="detail-section-title" style="margin-top:1rem;">📋 Entrega al Contador</div>
                        <% entregaKeys.forEach(bName => { const mEnt = c.entregaPorBanco[bName]; if(mEnt > 0) { %>
                        <div class="line-item">
                            <span class="line-label"><%= bName %></span>
                            <span class="line-value purple">L <%= mEnt.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } }); %>
                        <% } %>

                        <% if(c.observaciones) { %>
                        <div style="margin-top:0.75rem; padding:0.6rem 0.8rem; border-radius:8px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07);">
                            <span style="font-size:0.72rem; color:var(--text-muted); font-weight:600; text-transform:uppercase;">Observaciones</span>
                            <div style="font-size:0.82rem; color:#ccc; margin-top:0.25rem;"><%= c.observaciones %></div>
                        </div>
                        <% } %>
                    </div>
                </div>

                <!-- ACCIONES -->
                <div class="cierre-actions">
                    <button class="btn-pdf-card" onclick="generarPDFCierre(<%= idx %>)">📄 Generar PDF</button>
                    <% if(user.rol === 'Admin') { %>
                    <form action="/cierres/eliminar/<%= c.id %>" method="POST" 
                          onsubmit="return confirm('⚠️ ¿Revertir este cierre?\n\n• Se restaurará el saldo a la tienda.\n• La caja volverá a estado Abierta.\n• Se eliminarán las remesas pendientes asociadas.');"
                          style="display:inline;">
                        <button type="submit" class="btn-revert">↩ Revertir Cierre</button>
                    </form>
                    <% } %>
                </div>
            </div>

        </div>
        <% }); %>
        <% } %>

    </main>

    <!-- ============================================================ -->
    <!-- DATOS EMBEBIDOS PARA PDF (JSON en script oculto) -->
    <!-- ============================================================ -->
    <script id="cierres-data" type="application/json">
        <%- JSON.stringify(cierres.map(c => ({
            id: c.id,
            tienda_nombre: c.tienda_nombre,
            username: c.username,
            fecha: c.fecha,
            saldo_real: c.saldo_real,
            saldo_teorico: c.saldo_teorico,
            diferencia: c.diferencia,
            observaciones: c.observaciones,
            resumen: c.resumen,
            txBancos: c.txBancos,
            saldoInicialEf: c.saldoInicialEf,
            totalMovido: c.totalMovido,
            totalEntregado: c.totalEntregado,
            entregaPorBanco: c.entregaPorBanco,
            declaradoPorBanco: c.declaradoPorBanco
        }))) %>
    </script>

    <script>
        // ============================================================
        // TOGGLE EXPAND
        // ============================================================
        function toggleCard(idx) {
            const card = document.getElementById('card-' + idx);
            card.classList.toggle('expanded');
        }

        // ============================================================
        // PDF NATIVO CON jsPDF
        // ============================================================
        const cierresData = JSON.parse(document.getElementById('cierres-data').textContent);

        function lp(n) {
            const num = parseFloat(n) || 0;
            return 'L ' + num.toLocaleString('es-HN', { minimumFractionDigits: 2 });
        }
        function fmtFecha(str) {
            if (!str) return '—';
            const d = new Date(str);
            return d.toLocaleString('es-HN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        }

        function generarPDFCierre(idx) {
            const { jsPDF } = window.jspdf;
            const c = cierresData[idx];
            const doc = new jsPDF({ unit: 'mm', format: 'letter', orientation: 'portrait' });

            const pageW = doc.internal.pageSize.getWidth();
            const margin = 15;
            const colW = (pageW - margin * 2);
            let y = margin;

            // ---- PALETA ----
            const DARK    = [10, 10, 15];
            const BLUE    = [10, 132, 255];
            const GREEN   = [52, 199, 89];
            const RED     = [255, 69, 58];
            const ORANGE  = [255, 159, 10];
            const PURPLE  = [175, 82, 222];
            const GRAY    = [120, 120, 130];
            const LIGHT   = [220, 220, 230];
            const BG_CARD = [22, 22, 28];
            const BG_DARK = [14, 14, 18];

            // ---- FONDO ----
            doc.setFillColor(...BG_DARK);
            doc.rect(0, 0, pageW, doc.internal.pageSize.getHeight(), 'F');

            // ---- CABECERA ----
            doc.setFillColor(...BLUE);
            doc.rect(0, 0, pageW, 28, 'F');

            doc.setTextColor(255, 255, 255);
            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.text('SOLUCELS CONTROL', margin, 11);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.text('Reporte de Cierre de Caja', margin, 17);
            doc.setFontSize(8);
            doc.text('Generado: ' + fmtFecha(new Date().toISOString()), margin, 22);

            // Logo placeholder derecha
            doc.setFillColor(255, 255, 255, 0.2);
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(20);
            doc.text('🔒', pageW - margin - 8, 17);

            y = 35;

            // ---- INFO TIENDA ----
            doc.setFillColor(...BG_CARD);
            doc.roundedRect(margin, y, colW, 22, 3, 3, 'F');

            doc.setTextColor(...LIGHT);
            doc.setFontSize(13);
            doc.setFont('helvetica', 'bold');
            doc.text(c.tienda_nombre || '—', margin + 5, y + 8);

            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(...GRAY);
            doc.text('Cajero: ' + (c.username || '—'), margin + 5, y + 14);
            doc.text('Fecha: ' + fmtFecha(c.fecha), margin + 5, y + 19);

            // Diferencia badge
            const dif = c.diferencia || 0;
            const [difR, difG, difB] = Math.abs(dif) < 0.01 ? GREEN : (dif < 0 ? RED : ORANGE);
            doc.setFillColor(difR, difG, difB);
            const difTxt = Math.abs(dif) < 0.01 ? 'CUADRA' : (dif < 0 ? 'FALTA ' + lp(Math.abs(dif)) : 'SOBRA ' + lp(dif));
            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(255, 255, 255);
            const bW = doc.getTextWidth(difTxt) + 8;
            doc.roundedRect(pageW - margin - bW - 2, y + 6, bW + 2, 10, 2, 2, 'F');
            doc.text(difTxt, pageW - margin - bW + 2, y + 13);

            y += 28;

            // ---- MÉTRICAS CLAVE ----
            const metrics = [
                { label: 'Total Movido', value: lp(c.totalMovido), color: GREEN },
                { label: 'Depósitos a Banco', value: lp(c.resumen?.deposito_cuenta), color: ORANGE },
                { label: 'Total Retiros', value: lp(c.resumen?.retiros), color: RED },
                { label: 'Ef. Entregado', value: lp(c.totalEntregado), color: PURPLE },
                { label: 'Real Declarado', value: lp(c.saldo_real), color: LIGHT },
                { label: 'Queda Mañana', value: lp(Math.max(0, (c.saldo_real||0) - (c.totalEntregado||0))), color: BLUE },
            ];

            const cols = 3;
            const mW = (colW - (cols - 1) * 3) / cols;
            const mH = 18;
            metrics.forEach((m, i) => {
                const col = i % cols;
                const row = Math.floor(i / cols);
                const mx = margin + col * (mW + 3);
                const my = y + row * (mH + 3);

                doc.setFillColor(...BG_CARD);
                doc.roundedRect(mx, my, mW, mH, 2, 2, 'F');

                // Barra de color lateral
                doc.setFillColor(...m.color);
                doc.rect(mx, my, 2, mH, 'F');

                doc.setFontSize(6.5);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(...GRAY);
                doc.text(m.label.toUpperCase(), mx + 5, my + 6);

                doc.setFontSize(10);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(...m.color);
                doc.text(m.value, mx + 5, my + 14);
            });

            y += Math.ceil(metrics.length / cols) * (mH + 3) + 6;

            // ---- OPERACIONES POR TIPO ----
            doc.setFillColor(...BG_CARD);
            doc.roundedRect(margin, y, colW, 8, 2, 2, 'F');
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...BLUE);
            doc.text('OPERACIONES DEL TURNO', margin + 4, y + 5.5);
            y += 11;

            const ops = [];
            const r = c.resumen || {};
            if ((r.depositos||0) > 0)        ops.push({ label: 'Depósitos Recibidos', val: lp(r.depositos), color: GREEN, sign: '+' });
            if ((r.retiros||0) > 0)           ops.push({ label: 'Retiros', val: lp(r.retiros), color: RED, sign: '-' });
            if ((r.pagos_servicio||0) > 0)    ops.push({ label: 'Pagos de Servicio', val: lp(r.pagos_servicio), color: GREEN, sign: '+' });
            if ((r.caja_empresarial||0) > 0)  ops.push({ label: 'Caja Empresarial', val: lp(r.caja_empresarial), color: GREEN, sign: '+' });
            if ((r.deposito_cuenta||0) > 0)   ops.push({ label: 'Depósitos a Cuenta Bancaria', val: lp(r.deposito_cuenta), color: ORANGE, sign: '-' });
            if ((r.efectivo_entregado||0) > 0) ops.push({ label: 'Efectivo en Tránsito', val: lp(r.efectivo_entregado), color: PURPLE, sign: '-' });
            if ((c.totalEntregado||0) > 0)    ops.push({ label: 'Total Entregado al Contador', val: lp(c.totalEntregado), color: PURPLE, sign: '-' });

            if (ops.length === 0) {
                doc.setFontSize(8);
                doc.setTextColor(...GRAY);
                doc.text('Sin operaciones en este turno.', margin + 4, y + 4);
                y += 8;
            } else {
                ops.forEach((op, i) => {
                    doc.setFillColor(i % 2 === 0 ? 18 : 22, i % 2 === 0 ? 18 : 22, i % 2 === 0 ? 24 : 28);
                    doc.rect(margin, y, colW, 7, 'F');

                    doc.setFontSize(8);
                    doc.setFont('helvetica', 'normal');
                    doc.setTextColor(...LIGHT);
                    doc.text(op.sign + ' ' + op.label, margin + 4, y + 5);

                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(...op.color);
                    doc.text(op.val, pageW - margin - 2, y + 5, { align: 'right' });
                    y += 7;
                });

                // Totalizador
                const quedaMañana = Math.max(0, (c.saldo_real||0) - (c.totalEntregado||0));
                doc.setFillColor(10, 40, 10);
                doc.rect(margin, y, colW, 10, 'F');
                doc.setFontSize(9);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(...GREEN);
                doc.text('🌅 QUEDA PARA MAÑANA', margin + 4, y + 7);
                doc.text(lp(quedaMañana), pageW - margin - 2, y + 7, { align: 'right' });
                y += 14;
            }

            y += 3;

            // ---- DESGLOSE POR BANCO ----
            if (c.txBancos && c.txBancos.length > 0) {
                doc.setFillColor(...BG_CARD);
                doc.roundedRect(margin, y, colW, 8, 2, 2, 'F');
                doc.setFontSize(8);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(...BLUE);
                doc.text('DESGLOSE POR BANCO', margin + 4, y + 5.5);
                y += 11;

                // Encabezado tabla
                doc.setFillColor(30, 30, 40);
                doc.rect(margin, y, colW, 7, 'F');
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(...GRAY);
                const col1 = margin + 4, col2 = margin + colW * 0.35, col3 = margin + colW * 0.55, col4 = margin + colW * 0.75;
                doc.text('BANCO', col1, y + 5);
                doc.text('ENTRADA EF.', col2, y + 5);
                doc.text('SALIDA EF.', col3, y + 5);
                doc.text('NETO', col4, y + 5);
                y += 7;

                c.txBancos.forEach((b, i) => {
                    // Check page overflow
                    if (y > 255) {
                        doc.addPage();
                        doc.setFillColor(...BG_DARK);
                        doc.rect(0, 0, pageW, doc.internal.pageSize.getHeight(), 'F');
                        y = margin;
                    }
                    doc.setFillColor(i % 2 === 0 ? 18 : 22, i % 2 === 0 ? 18 : 24, i % 2 === 0 ? 24 : 30);
                    doc.rect(margin, y, colW, 7, 'F');

                    // Barra de color del banco
                    doc.setFillColor(100, 100, 100);
                    doc.rect(margin, y, 2, 7, 'F');

                    doc.setFontSize(7.5);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(...LIGHT);
                    doc.text(b.banco_nombre || '—', col1, y + 5);

                    doc.setFont('helvetica', 'normal');
                    doc.setTextColor(...GREEN);
                    doc.text(lp(b.entrada_ef||0), col2, y + 5);

                    doc.setTextColor(...RED);
                    doc.text(lp(b.salida_ef||0), col3, y + 5);

                    const netoCol = (b.neto_ef||0) >= 0 ? GREEN : RED;
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(...netoCol);
                    doc.text(lp(b.neto_ef||0), col4, y + 5);

                    y += 7;
                });
                y += 4;
            }

            // ---- OBSERVACIONES ----
            if (c.observaciones) {
                doc.setFillColor(...BG_CARD);
                doc.roundedRect(margin, y, colW, 16, 2, 2, 'F');
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(...GRAY);
                doc.text('OBSERVACIONES', margin + 4, y + 6);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(...LIGHT);
                const obsLines = doc.splitTextToSize(c.observaciones, colW - 8);
                doc.text(obsLines, margin + 4, y + 12);
                y += 20;
            }

            // ---- FOOTER ----
            const pageH = doc.internal.pageSize.getHeight();
            doc.setFillColor(30, 30, 40);
            doc.rect(0, pageH - 12, pageW, 12, 'F');
            doc.setFontSize(7);
            doc.setTextColor(...GRAY);
            doc.text('Solucels Control Agentes Bancarios · Documento oficial de cierre', margin, pageH - 4);
            doc.text('Página 1', pageW - margin, pageH - 4, { align: 'right' });

            // ---- GUARDAR ----
            const fechaStr = c.fecha ? new Date(c.fecha).toLocaleDateString('es-HN').replace(/\//g, '-') : 'fecha';
            doc.save(`Cierre_${c.tienda_nombre}_${fechaStr}.pdf`);
        }
    </script>
</body>
</html>
