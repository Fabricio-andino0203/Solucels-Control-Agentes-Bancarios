<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Cierres de Caja - Solucels Control</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        .cierres-title { font-size: 1.5rem; font-weight: 900; color: #fff; }
        .cierres-subtitle { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.2rem; }

        .summary-strip {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }
        .summary-chip {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px;
            padding: 0.85rem 1.1rem;
        }
        .summary-chip-label { font-size: 0.7rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }
        .summary-chip-value { font-size: 1.2rem; font-weight: 900; margin-top: 0.2rem; }

        .cierre-card {
            background: var(--bg-card);
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.07);
            margin-bottom: 1.25rem;
            overflow: hidden;
            transition: border-color 0.2s;
        }
        .cierre-card:hover { border-color: rgba(10,132,255,0.3); }

        .cierre-card-header {
            display: grid;
            grid-template-columns: auto 1fr auto auto;
            align-items: center;
            gap: 1.25rem;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            cursor: pointer;
            user-select: none;
        }
        .cierre-card-header:hover { background: rgba(255,255,255,0.02); }

        .cierre-badge {
            width: 40px; height: 40px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            background: rgba(10,132,255,0.12);
            border: 1px solid rgba(10,132,255,0.25);
            flex-shrink: 0;
        }
        .cierre-info { min-width: 0; }
        .cierre-tienda { font-weight: 800; font-size: 0.95rem; color: #fff; }
        .cierre-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem; }

        .cierre-dif-badge {
            padding: 0.3rem 0.75rem;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 700;
            white-space: nowrap;
        }
        .dif-ok { background: rgba(52,199,89,0.12); color: #34C759; border: 1px solid rgba(52,199,89,0.3); }
        .dif-falta { background: rgba(255,69,58,0.12); color: #FF453A; border: 1px solid rgba(255,69,58,0.3); }
        .dif-sobra { background: rgba(255,159,10,0.12); color: #FF9F0A; border: 1px solid rgba(255,159,10,0.3); }

        .cierre-chevron { font-size: 0.85rem; color: var(--text-muted); transition: transform 0.3s; flex-shrink: 0; }
        .cierre-card.expanded .cierre-chevron { transform: rotate(180deg); }

        .cierre-detail { display: none; animation: fadeIn 0.2s ease; }
        .cierre-card.expanded .cierre-detail { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .detail-stat { padding: 1rem 1.25rem; border-right: 1px solid rgba(255,255,255,0.05); }
        .detail-stat:last-child { border-right: none; }
        .detail-stat-label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 0.3rem; }
        .detail-stat-value { font-size: 1.1rem; font-weight: 900; color: #fff; }

        .detail-body { display: grid; grid-template-columns: 1fr 1fr; }
        @media(max-width: 768px) { .detail-body { grid-template-columns: 1fr; } }
        .detail-section { padding: 1.1rem 1.25rem; border-right: 1px solid rgba(255,255,255,0.05); }
        .detail-section:last-child { border-right: none; }
        .detail-section-title { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); }

        .line-item { display: flex; justify-content: space-between; align-items: center; padding: 0.4rem 0; font-size: 0.85rem; border-bottom: 1px solid rgba(255,255,255,0.03); }
        .line-item:last-child { border-bottom: none; }
        .line-label { color: var(--text-muted); }
        .line-value { font-weight: 700; color: #fff; }
        .line-value.green { color: #34C759; }
        .line-value.red { color: #FF453A; }
        .line-value.orange { color: #FF9F0A; }
        .line-value.blue { color: var(--accent-blue); }
        .line-value.purple { color: #AF52DE; }

        .bank-dot-sm { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 5px; flex-shrink: 0; }

        .cierre-actions {
            padding: 0.85rem 1.25rem;
            background: rgba(0,0,0,0.15);
            border-top: 1px solid rgba(255,255,255,0.04);
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }
        .btn-pdf-card { background: rgba(10,132,255,0.12); border: 1px solid rgba(10,132,255,0.3); color: var(--accent-blue); padding: 0.45rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.82rem; font-weight: 700; transition: all 0.2s; }
        .btn-pdf-card:hover { background: rgba(10,132,255,0.25); }
        .btn-revert { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: var(--text-muted); padding: 0.45rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.82rem; font-weight: 700; transition: all 0.2s; text-decoration: none; }
        .btn-revert:hover { background: rgba(255,69,58,0.1); color: #FF453A; border-color: rgba(255,69,58,0.3); }

        .empty-state { text-align: center; padding: 4rem 2rem; color: var(--text-muted); }
        .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { active: 'cierres', user: user }) %>
    <main class="main-content">

        <div class="header">
            <div>
                <div class="cierres-title">Registro de Cierres</div>
                <div class="cierres-subtitle">Historial completo de cierres de caja por tienda</div>
            </div>
            <div style="display:flex; gap:0.75rem; align-items:center;">
                <span style="font-size:0.85rem; color:var(--text-muted);"><%= user.username %> (<%= user.rol %>)</span>
                <a href="/logout" style="color:#FF453A; font-size:0.85rem;">Salir</a>
            </div>
        </div>

        <%
        const totalGlobalOps    = cierres.reduce((a,c) => a + (c.resumen ? c.resumen.total_ops : 0), 0);
        const totalGlobalDep    = cierres.reduce((a,c) => a + (c.resumen ? c.resumen.depositos : 0), 0);
        const totalGlobalRet    = cierres.reduce((a,c) => a + (c.resumen ? c.resumen.retiros : 0), 0);
        const totalGlobalEntreg = cierres.reduce((a,c) => a + (c.totalEntregado || 0), 0);
        %>

        <% if(cierres.length > 0) { %>
        <div class="summary-strip">
            <div class="summary-chip">
                <div class="summary-chip-label">Total Cierres</div>
                <div class="summary-chip-value" style="color:#fff;"><%= cierres.length %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Depositos</div>
                <div class="summary-chip-value" style="color:#34C759;">L <%= totalGlobalDep.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Retiros</div>
                <div class="summary-chip-value" style="color:#FF453A;">L <%= totalGlobalRet.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Total Entregado</div>
                <div class="summary-chip-value" style="color:#AF52DE;">L <%= totalGlobalEntreg.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
            </div>
            <div class="summary-chip">
                <div class="summary-chip-label">Operaciones</div>
                <div class="summary-chip-value" style="color:var(--accent-blue);"><%= totalGlobalOps %></div>
            </div>
        </div>
        <% } %>

        <% if(cierres.length === 0) { %>
        <div class="empty-state">
            <div class="empty-icon">&#128219;</div>
            <div style="font-size:1.1rem; font-weight:700; margin-bottom:0.5rem;">No hay cierres registrados</div>
            <div style="font-size:0.85rem;">Los cierres se registran desde el POS al finalizar el turno.</div>
        </div>
        <% } else { %>

        <% cierres.forEach((c, idx) => {
            const dif = c.diferencia || 0;
            const difClass = Math.abs(dif) < 0.01 ? 'dif-ok' : (dif < 0 ? 'dif-falta' : 'dif-sobra');
            const difLabel = Math.abs(dif) < 0.01 ? 'CUADRA' : (dif < 0 ? 'FALTA L ' + Math.abs(dif).toFixed(2) : 'SOBRA L ' + dif.toFixed(2));
            const r = c.resumen || {};
            const quedaMañana = Math.max(0, (c.saldo_real||0) - (c.totalEntregado||0));
        %>
        <div class="cierre-card" id="card-<%= idx %>">
            <div class="cierre-card-header" onclick="toggleCard(<%= idx %>)">
                <div class="cierre-badge">&#128274;</div>
                <div class="cierre-info">
                    <div class="cierre-tienda"><%= c.tienda_nombre %></div>
                    <div class="cierre-meta">
                        <%= new Date(c.fecha).toLocaleString('es-HN', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                        &nbsp;&middot;&nbsp; Cajero: <strong><%= c.username %></strong>
                        &nbsp;&middot;&nbsp; <%= (r.total_ops || 0) %> operaciones
                    </div>
                </div>
                <div class="cierre-dif-badge <%= difClass %>"><%= difLabel %></div>
                <div class="cierre-chevron">&#9660;</div>
            </div>

            <div class="cierre-detail">
                <div class="detail-grid">
                    <div class="detail-stat">
                        <div class="detail-stat-label">Total Movido (Entrada Ef.)</div>
                        <div class="detail-stat-value" style="color:#34C759;">L <%= (c.totalMovido||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Depositos a Banco</div>
                        <div class="detail-stat-value" style="color:#FF9F0A;">L <%= (r.deposito_cuenta||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Efectivo Entregado</div>
                        <div class="detail-stat-value" style="color:#AF52DE;">L <%= (c.totalEntregado||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Queda para Manana</div>
                        <div class="detail-stat-value" style="color:var(--accent-blue);">L <%= quedaMañana.toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Real Declarado</div>
                        <div class="detail-stat-value">L <%= (c.saldo_real||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Teorico del Sistema</div>
                        <div class="detail-stat-value" style="color:var(--text-muted);">L <%= (c.saldo_teorico||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></div>
                    </div>
                </div>

                <div class="detail-body">
                    <div class="detail-section">
                        <div class="detail-section-title">Operaciones del Turno</div>
                        <% if((r.depositos||0) > 0) { %>
                        <div class="line-item"><span class="line-label">Depositos recibidos</span><span class="line-value green">+ L <%= r.depositos.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                        <% } %>
                        <% if((r.retiros||0) > 0) { %>
                        <div class="line-item"><span class="line-label">Retiros</span><span class="line-value red">- L <%= r.retiros.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                        <% } %>
                        <% if((r.pagos_servicio||0) > 0) { %>
                        <div class="line-item"><span class="line-label">Pagos de Servicio</span><span class="line-value green">+ L <%= r.pagos_servicio.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                        <% } %>
                        <% if((r.caja_empresarial||0) > 0) { %>
                        <div class="line-item"><span class="line-label">Caja Empresarial</span><span class="line-value green">+ L <%= r.caja_empresarial.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                        <% } %>
                        <% if((r.deposito_cuenta||0) > 0) { %>
                        <div class="line-item"><span class="line-label">Depositos a Cuenta</span><span class="line-value orange">- L <%= r.deposito_cuenta.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                        <% } %>
                        <% if((r.efectivo_entregado||0) > 0) { %>
                        <div class="line-item"><span class="line-label">Efectivo en Transito</span><span class="line-value purple">- L <%= r.efectivo_entregado.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                        <% } %>
                        <% if((r.total_ops||0) === 0) { %>
                        <div style="color:var(--text-muted); font-size:0.82rem; padding:0.5rem 0;">Sin operaciones en este turno</div>
                        <% } %>
                        <% if((c.totalEntregado||0) > 0) { %>
                        <div class="line-item" style="margin-top:0.5rem; padding-top:0.5rem; border-top:1px solid rgba(175,82,222,0.2);">
                            <span class="line-label" style="font-weight:700;">Total entregado al Contador</span>
                            <span class="line-value purple">L <%= (c.totalEntregado||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } %>
                        <div class="line-item" style="margin-top:0.5rem; padding-top:0.5rem; border-top:1px solid rgba(52,199,89,0.25); font-size:0.9rem;">
                            <span style="color:#34C759; font-weight:800;">Queda para manana</span>
                            <span class="line-value" style="color:#34C759; font-size:1rem;">L <%= quedaMañana.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                    </div>

                    <div class="detail-section">
                        <div class="detail-section-title">Desglose por Banco</div>
                        <% if(c.txBancos && c.txBancos.length > 0) { %>
                        <% c.txBancos.forEach(b => { %>
                        <div style="margin-bottom:0.75rem; padding:0.6rem 0.8rem; border-radius:8px; background:rgba(255,255,255,0.02); border-left:3px solid <%= b.banco_color || '#555' %>;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.3rem;">
                                <span style="color:<%= b.banco_color||'#aaa' %>; font-weight:700; font-size:0.85rem;">
                                    <span class="bank-dot-sm" style="background:<%= b.banco_color||'#555' %>;"></span>
                                    <%= b.banco_nombre %>
                                </span>
                                <span style="font-size:0.75rem; color:var(--text-muted);"><%= b.ops %> ops</span>
                            </div>
                            <% if((b.entrada_ef||0) > 0) { %>
                            <div class="line-item" style="padding:0.2rem 0;"><span class="line-label" style="font-size:0.78rem;">Entrada efectivo</span><span class="line-value green" style="font-size:0.82rem;">+ L <%= (b.entrada_ef||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                            <% } %>
                            <% if((b.salida_ef||0) > 0) { %>
                            <div class="line-item" style="padding:0.2rem 0;"><span class="line-label" style="font-size:0.78rem;">Salida efectivo</span><span class="line-value red" style="font-size:0.82rem;">- L <%= (b.salida_ef||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span></div>
                            <% } %>
                            <div class="line-item" style="padding:0.2rem 0;">
                                <span class="line-label" style="font-size:0.78rem; font-weight:700;">Neto efectivo</span>
                                <span class="line-value" style="font-size:0.85rem; color:<%= (b.neto_ef||0) >= 0 ? '#34C759' : '#FF453A' %>;">L <%= (b.neto_ef||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                            </div>
                        </div>
                        <% }); %>
                        <% } else { %>
                        <div style="color:var(--text-muted); font-size:0.82rem; padding:0.5rem 0;">Sin transacciones por banco en este turno</div>
                        <% } %>

                        <% const entregaKeys = Object.keys(c.entregaPorBanco || {}); %>
                        <% if(entregaKeys.length > 0) { %>
                        <div class="detail-section-title" style="margin-top:1rem;">Entrega al Contador</div>
                        <% entregaKeys.forEach(bName => { const mEnt = c.entregaPorBanco[bName]; if(mEnt > 0) { %>
                        <div class="line-item">
                            <span class="line-label"><%= bName %></span>
                            <span class="line-value purple">L <%= mEnt.toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                        </div>
                        <% } }); %>
                        <% } %>

                        <% if(c.observaciones) { %>
                        <div style="margin-top:0.75rem; padding:0.6rem 0.8rem; border-radius:8px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07);">
                            <span style="font-size:0.72rem; color:var(--text-muted); font-weight:600; text-transform:uppercase;">Observaciones</span>
                            <div style="font-size:0.82rem; color:#ccc; margin-top:0.25rem;"><%= c.observaciones %></div>
                        </div>
                        <% } %>
                    </div>
                </div>

                <div class="cierre-actions">
                    <button class="btn-pdf-card" onclick="generarPDFCierre(<%= idx %>)">Generar PDF</button>
                    <% if(user.rol === 'Admin') { %>
                    <form action="/cierres/eliminar/<%= c.id %>" method="POST"
                          onsubmit="return confirm('Revertir este cierre?\n\nSe restaurara el saldo a la tienda.\nLa caja volvera a estado Abierta.\nSe eliminaran las remesas pendientes asociadas.');"
                          style="display:inline;">
                        <button type="submit" class="btn-revert">Revertir Cierre</button>
                    </form>
                    <% } %>
                </div>
            </div>
        </div>
        <% }); %>
        <% } %>

    </main>

    <script id="cierres-data" type="application/json">
        <%- JSON.stringify(cierres.map(c => ({
            id: c.id,
            tienda_nombre: c.tienda_nombre,
            username: c.username,
            fecha: c.fecha,
            saldo_real: c.saldo_real,
            saldo_teorico: c.saldo_teorico,
            diferencia: c.diferencia,
            observaciones: c.observaciones,
            resumen: c.resumen,
            txBancos: c.txBancos,
            saldoInicialEf: c.saldoInicialEf,
            totalMovido: c.totalMovido,
            totalEntregado: c.totalEntregado,
            entregaPorBanco: c.entregaPorBanco,
            declaradoPorBanco: c.declaradoPorBanco
        }))) %>
    </script>

    <script>
        // ── TOGGLE ──────────────────────────────────────────────
        function toggleCard(idx) {
            document.getElementById('card-' + idx).classList.toggle('expanded');
        }

        // ── DATOS ───────────────────────────────────────────────
        const cierresData = JSON.parse(document.getElementById('cierres-data').textContent);

        // ── HELPERS ─────────────────────────────────────────────
        function lp(n) {
            const num = parseFloat(n) || 0;
            return 'L ' + num.toLocaleString('es-HN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        function fmtFecha(str) {
            if (!str) return '-';
            const d = new Date(str);
            return d.toLocaleDateString('es-HN', { day: '2-digit', month: '2-digit', year: 'numeric' })
                 + '  ' + d.toLocaleTimeString('es-HN', { hour: '2-digit', minute: '2-digit' });
        }
        function hLine(doc, x, y, w, r, g, b, lw) {
            doc.setDrawColor(r || 180, g || 185, b || 210);
            doc.setLineWidth(lw || 0.3);
            doc.line(x, y, x + w, y);
        }
        function secHeader(doc, label, x, y, w, aR, aG, aB) {
            doc.setFillColor(aR || 30, aG || 80, aB || 200);
            doc.rect(x, y, 3, 7, 'F');
            doc.setFillColor(245, 247, 253);
            doc.rect(x + 3, y, w - 3, 7, 'F');
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(25, 35, 70);
            doc.text(label, x + 7, y + 5.2);
            return y + 9;
        }

        // ── GENERADOR PDF ────────────────────────────────────────
        function generarPDFCierre(idx) {
            const { jsPDF } = window.jspdf;
            const c = cierresData[idx];
            const doc = new jsPDF({ unit: 'mm', format: 'letter', orientation: 'portrait' });

            const PW = doc.internal.pageSize.getWidth();
            const PH = doc.internal.pageSize.getHeight();
            const ML = 15, MR = 15;
            const CW = PW - ML - MR;
            let y = 0;

            // ═══════════════════════════════════
            // FONDO BLANCO (imprimible)
            // ═══════════════════════════════════
            doc.setFillColor(255, 255, 255);
            doc.rect(0, 0, PW, PH, 'F');

            // ═══════════════════════════════════
            // CABECERA — azul oscuro
            // ═══════════════════════════════════
            doc.setFillColor(18, 52, 130);
            doc.rect(0, 0, PW, 30, 'F');

            doc.setTextColor(255, 255, 255);
            doc.setFontSize(20);
            doc.setFont('helvetica', 'bold');
            doc.text('SOLUCELS CONTROL', ML, 13);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(180, 205, 255);
            doc.text('Agentes Bancarios  |  Reporte Oficial de Cierre de Caja', ML, 21);
            doc.setFontSize(7.5);
            doc.setTextColor(140, 170, 220);
            doc.text('Generado: ' + fmtFecha(new Date().toISOString()), PW - MR, 12, { align: 'right' });
            doc.text('Documento confidencial', PW - MR, 20, { align: 'right' });

            doc.setFillColor(60, 130, 255);
            doc.rect(0, 30, PW, 1.2, 'F');

            y = 38;

            // ═══════════════════════════════════
            // INFO TIENDA
            // ═══════════════════════════════════
            doc.setFontSize(15);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(12, 28, 85);
            doc.text(c.tienda_nombre || '-', ML, y);

            // Badge diferencia
            const dif = c.diferencia || 0;
            const difOk = Math.abs(dif) < 0.01;
            const [bR, bG, bB] = difOk ? [34, 120, 34] : (dif < 0 ? [170, 20, 20] : [190, 110, 0]);
            const difTxt = difOk ? 'CUADRA PERFECTO' : (dif < 0 ? 'FALTA ' + lp(Math.abs(dif)) : 'SOBRA ' + lp(dif));
            const dtW = doc.getTextWidth(difTxt) + 8;
            doc.setFillColor(bR, bG, bB);
            doc.roundedRect(PW - MR - dtW, y - 7, dtW, 9, 1.5, 1.5, 'F');
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(255, 255, 255);
            doc.text(difTxt, PW - MR - dtW + 4, y - 1);

            y += 5;
            doc.setFontSize(8.5);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(65, 75, 110);
            doc.text(
                'Cajero: ' + (c.username || '-') +
                '     Fecha del turno: ' + fmtFecha(c.fecha) +
                '     Operaciones: ' + (c.resumen ? c.resumen.total_ops : 0),
                ML, y
            );

            y += 3;
            hLine(doc, ML, y, CW, 190, 200, 225, 0.5);
            y += 6;

            // ═══════════════════════════════════
            // CUADRO DE METRICAS (3 col x 2 fil)
            // ═══════════════════════════════════
            const quedaMañana = Math.max(0, (c.saldo_real || 0) - (c.totalEntregado || 0));
            const r = c.resumen || {};
            const metrics = [
                { lbl: 'TOTAL MOVIDO (ENTRADA EFECTIVO)', val: lp(c.totalMovido),            aR:  34, aG: 120, aB:  34 },
                { lbl: 'DEPOSITOS A CUENTA BANCARIA',     val: lp(r.deposito_cuenta),         aR: 190, aG: 110, aB:   0 },
                { lbl: 'TOTAL RETIROS',                   val: lp(r.retiros),                 aR: 170, aG:  20, aB:  20 },
                { lbl: 'EFECTIVO ENTREGADO AL CONTADOR',  val: lp(c.totalEntregado),          aR: 110, aG:  35, aB: 190 },
                { lbl: 'REAL DECLARADO',                  val: lp(c.saldo_real),              aR:  18, aG:  52, aB: 130 },
                { lbl: 'QUEDA PARA MANANA',               val: lp(quedaMañana),               aR:   0, aG: 130, aB: 195 },
            ];

            const COLS = 3;
            const mW = (CW - (COLS - 1) * 4) / COLS;
            const mH = 16;

            metrics.forEach((m, i) => {
                const col = i % COLS;
                const row = Math.floor(i / COLS);
                const mx = ML + col * (mW + 4);
                const my = y + row * (mH + 3);

                // Tarjeta blanca con borde
                doc.setFillColor(255, 255, 255);
                doc.setDrawColor(200, 210, 228);
                doc.setLineWidth(0.3);
                doc.roundedRect(mx, my, mW, mH, 1.5, 1.5, 'FD');

                // Linea de acento superior
                doc.setFillColor(m.aR, m.aG, m.aB);
                doc.rect(mx, my, mW, 2.2, 'F');

                // Label
                doc.setFontSize(5.8);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(95, 105, 140);
                doc.text(m.lbl, mx + 3, my + 7.5);

                // Valor
                doc.setFontSize(10.5);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(m.aR, m.aG, m.aB);
                doc.text(m.val, mx + 3, my + 14);
            });

            y += Math.ceil(metrics.length / COLS) * (mH + 3) + 5;

            // ═══════════════════════════════════
            // SECCION: OPERACIONES DEL TURNO
            // ═══════════════════════════════════
            y = secHeader(doc, 'RESUMEN DE OPERACIONES DEL TURNO', ML, y, CW, 18, 52, 130);

            const ops = [];
            if ((r.depositos          || 0) > 0) ops.push({ lbl: 'Depositos recibidos (efectivo entrante)', val: lp(r.depositos),          sg: '+', cR:  34, cG: 120, cB:  34 });
            if ((r.retiros            || 0) > 0) ops.push({ lbl: 'Retiros atendidos',                       val: lp(r.retiros),            sg: '-', cR: 170, cG:  20, cB:  20 });
            if ((r.pagos_servicio     || 0) > 0) ops.push({ lbl: 'Pagos de Servicio',                       val: lp(r.pagos_servicio),     sg: '+', cR:  34, cG: 120, cB:  34 });
            if ((r.caja_empresarial   || 0) > 0) ops.push({ lbl: 'Caja Empresarial',                        val: lp(r.caja_empresarial),   sg: '+', cR:  34, cG: 120, cB:  34 });
            if ((r.deposito_cuenta    || 0) > 0) ops.push({ lbl: 'Depositos a Cuenta Bancaria',             val: lp(r.deposito_cuenta),    sg: '-', cR: 190, cG: 110, cB:   0 });
            if ((r.efectivo_entregado || 0) > 0) ops.push({ lbl: 'Efectivo en Transito (sin banco)',        val: lp(r.efectivo_entregado), sg: '-', cR: 110, cG:  35, cB: 190 });

            if (ops.length === 0) {
                doc.setFontSize(8.5);
                doc.setFont('helvetica', 'italic');
                doc.setTextColor(140, 145, 165);
                doc.text('Sin operaciones registradas en este turno.', ML + 4, y + 5);
                y += 10;
            } else {
                // Encabezado
                doc.setFillColor(238, 242, 252);
                doc.rect(ML, y, CW, 7, 'F');
                hLine(doc, ML, y, CW, 170, 180, 215);
                hLine(doc, ML, y + 7, CW, 170, 180, 215);
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(55, 65, 100);
                doc.text('CONCEPTO', ML + 4, y + 5);
                doc.text('SIGNO', PW - MR - 54, y + 5);
                doc.text('MONTO', PW - MR, y + 5, { align: 'right' });
                y += 7;

                ops.forEach((op, i) => {
                    if (i % 2 === 1) {
                        doc.setFillColor(250, 251, 255);
                        doc.rect(ML, y, CW, 7, 'F');
                    }
                    hLine(doc, ML, y + 7, CW, 228, 232, 245, 0.2);
                    doc.setFontSize(8);
                    doc.setFont('helvetica', 'normal');
                    doc.setTextColor(35, 45, 70);
                    doc.text(op.lbl, ML + 4, y + 5);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(op.cR, op.cG, op.cB);
                    doc.text(op.sg, PW - MR - 54, y + 5);
                    doc.text(op.val, PW - MR, y + 5, { align: 'right' });
                    y += 7;
                });

                // Subtotal entregado al contador
                if ((c.totalEntregado || 0) > 0) {
                    hLine(doc, ML, y, CW, 95, 45, 175, 0.4);
                    doc.setFillColor(244, 240, 255);
                    doc.rect(ML, y, CW, 8, 'F');
                    doc.setFontSize(8.5);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(95, 28, 175);
                    doc.text('Total entregado al Contador', ML + 4, y + 5.5);
                    doc.text(lp(c.totalEntregado), PW - MR, y + 5.5, { align: 'right' });
                    y += 8;
                }

                // Fila QUEDA PARA MANANA
                hLine(doc, ML, y, CW, 18, 125, 18, 0.5);
                doc.setFillColor(232, 252, 236);
                doc.rect(ML, y, CW, 10, 'F');
                doc.setFontSize(9.5);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(15, 110, 25);
                doc.text('QUEDA PARA MANANA', ML + 4, y + 7);
                doc.text(lp(quedaMañana), PW - MR, y + 7, { align: 'right' });
                y += 12;
            }

            y += 5;

            // ═══════════════════════════════════
            // SECCION: DESGLOSE POR BANCO
            // ═══════════════════════════════════
            if (c.txBancos && c.txBancos.length > 0) {
                if (y > PH - 75) { doc.addPage(); y = 20; }

                y = secHeader(doc, 'DESGLOSE POR BANCO', ML, y, CW, 18, 52, 130);

                // Encabezado tabla
                doc.setFillColor(18, 52, 130);
                doc.rect(ML, y, CW, 7, 'F');
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(255, 255, 255);
                const C1 = ML + 4, C2 = ML + CW * 0.37, C3 = ML + CW * 0.55, C4 = ML + CW * 0.73, C5 = PW - MR;
                doc.text('BANCO', C1, y + 5);
                doc.text('OPS', C2, y + 5);
                doc.text('ENTRADA EF.', C3, y + 5);
                doc.text('SALIDA EF.', C4, y + 5);
                doc.text('NETO', C5, y + 5, { align: 'right' });
                y += 7;

                c.txBancos.forEach((b, i) => {
                    if (y > PH - 30) { doc.addPage(); y = 20; }

                    if (i % 2 === 1) {
                        doc.setFillColor(248, 250, 255);
                        doc.rect(ML, y, CW, 8, 'F');
                    }
                    hLine(doc, ML, y + 8, CW, 215, 220, 240, 0.2);

                    // Acento banco
                    doc.setFillColor(50, 90, 195);
                    doc.rect(ML, y, 2.5, 8, 'F');

                    doc.setFontSize(8.5);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(18, 32, 70);
                    doc.text(b.banco_nombre || '-', C1, y + 5.5);

                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(8);
                    doc.setTextColor(75, 85, 120);
                    doc.text(String(b.ops || 0) + ' ops', C2, y + 5.5);

                    doc.setTextColor(34, 120, 34);
                    doc.text(lp(b.entrada_ef || 0), C3, y + 5.5);

                    doc.setTextColor(170, 20, 20);
                    doc.text(lp(b.salida_ef || 0), C4, y + 5.5);

                    const neto = b.neto_ef || 0;
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(neto >= 0 ? 18 : 170, neto >= 0 ? 115 : 20, neto >= 0 ? 28 : 20);
                    doc.text(lp(neto), C5, y + 5.5, { align: 'right' });

                    y += 8;
                });

                // Fila totales
                hLine(doc, ML, y, CW, 35, 55, 110, 0.5);
                doc.setFillColor(233, 238, 255);
                doc.rect(ML, y, CW, 9, 'F');
                const totEnt = c.txBancos.reduce((a, b) => a + (b.entrada_ef || 0), 0);
                const totSal = c.txBancos.reduce((a, b) => a + (b.salida_ef || 0), 0);
                const totNet = c.txBancos.reduce((a, b) => a + (b.neto_ef || 0), 0);
                doc.setFontSize(8);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(18, 38, 100);
                doc.text('TOTALES', C1, y + 6.5);
                doc.setTextColor(34, 120, 34);
                doc.text(lp(totEnt), C3, y + 6.5);
                doc.setTextColor(170, 20, 20);
                doc.text(lp(totSal), C4, y + 6.5);
                doc.setTextColor(totNet >= 0 ? 18 : 170, totNet >= 0 ? 115 : 20, totNet >= 0 ? 28 : 20);
                doc.text(lp(totNet), C5, y + 6.5, { align: 'right' });
                y += 11;
            }

            // ═══════════════════════════════════
            // SECCION: ENTREGA AL CONTADOR
            // ═══════════════════════════════════
            const entKeys = Object.keys(c.entregaPorBanco || {}).filter(k => (c.entregaPorBanco[k] || 0) > 0);
            if (entKeys.length > 0) {
                if (y > PH - 55) { doc.addPage(); y = 20; }
                y += 3;
                y = secHeader(doc, 'DETALLE DE ENTREGA AL CONTADOR', ML, y, CW, 95, 28, 175);

                doc.setFillColor(18, 52, 130);
                doc.rect(ML, y, CW, 7, 'F');
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(255, 255, 255);
                doc.text('BANCO / CATEGORIA', ML + 4, y + 5);
                doc.text('MONTO ENTREGADO', PW - MR, y + 5, { align: 'right' });
                y += 7;

                entKeys.forEach((k, i) => {
                    if (i % 2 === 1) {
                        doc.setFillColor(248, 244, 255);
                        doc.rect(ML, y, CW, 7, 'F');
                    }
                    hLine(doc, ML, y + 7, CW, 218, 212, 240, 0.2);
                    doc.setFontSize(8.5);
                    doc.setFont('helvetica', 'normal');
                    doc.setTextColor(48, 28, 100);
                    doc.text(k, ML + 4, y + 5);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(95, 28, 175);
                    doc.text(lp(c.entregaPorBanco[k]), PW - MR, y + 5, { align: 'right' });
                    y += 7;
                });
                y += 3;
            }

            // ═══════════════════════════════════
            // OBSERVACIONES
            // ═══════════════════════════════════
            if (c.observaciones) {
                if (y > PH - 45) { doc.addPage(); y = 20; }
                y += 3;
                doc.setFillColor(255, 252, 225);
                doc.setDrawColor(195, 172, 45);
                doc.setLineWidth(0.4);
                doc.roundedRect(ML, y, CW, 16, 2, 2, 'FD');
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(135, 95, 0);
                doc.text('OBSERVACIONES:', ML + 4, y + 6.5);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(75, 55, 0);
                doc.text(doc.splitTextToSize(c.observaciones, CW - 8), ML + 4, y + 12.5);
                y += 20;
            }

            // ═══════════════════════════════════
            // LINEAS DE FIRMA
            // ═══════════════════════════════════
            const firmaY = Math.max(y + 5, PH - 42);
            hLine(doc, ML, firmaY, CW, 175, 185, 210, 0.4);
            const fW = (CW - 10) / 3;
            const firmantes = ['Cajero: ' + (c.username || '___________'), 'Contador: _______________', 'Administrador: ____________'];
            doc.setFontSize(7.5);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(95, 105, 140);
            firmantes.forEach((txt, i) => {
                const fx = ML + i * (fW + 5);
                hLine(doc, fx, firmaY + 12, fW, 110, 120, 155, 0.3);
                doc.text(txt, fx + fW / 2, firmaY + 17, { align: 'center' });
            });

            // ═══════════════════════════════════
            // FOOTER
            // ═══════════════════════════════════
            doc.setFillColor(18, 52, 130);
            doc.rect(0, PH - 10, PW, 10, 'F');
            doc.setFontSize(7);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(165, 188, 230);
            doc.text('Solucels Control Agentes Bancarios  |  Documento oficial de cierre  |  Confidencial', ML, PH - 3.5);
            doc.text('Pag. 1 de 1', PW - MR, PH - 3.5, { align: 'right' });

            // ═══════════════════════════════════
            // GUARDAR
            // ═══════════════════════════════════
            const fechaStr = c.fecha
                ? new Date(c.fecha).toLocaleDateString('es-HN').replace(/\//g, '-')
                : 'fecha';
            doc.save('Cierre_' + (c.tienda_nombre || 'tienda') + '_' + fechaStr + '.pdf');
        }
    </script>
</body>
</html>
