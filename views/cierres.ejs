<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Cierres y PDF - Solucels Control Agentes Bancarios</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        .cierre-layout { display: grid; grid-template-columns: 420px 1fr; gap: 1.5rem; align-items: start; }
        @media(max-width: 1100px){ .cierre-layout { grid-template-columns: 1fr; } }

        .panel-cierre {
            background: var(--bg-card);
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.06);
            overflow: hidden;
            position: sticky;
            top: 1rem;
        }

        .step-block {
            padding: 1.1rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .step-block:last-child { border-bottom: none; }

        .step-header {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 0.75rem;
        }
        .step-num {
            width: 24px; height: 24px;
            border-radius: 50%;
            background: var(--accent-blue);
            color: #fff;
            font-size: 0.7rem;
            font-weight: 800;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .step-title { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #fff; }

        .banco-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
            align-items: center;
            margin-bottom: 0.6rem;
        }
        .banco-label {
            display: flex; align-items: center; gap: 0.4rem;
            font-size: 0.8rem; font-weight: 600;
        }
        .banco-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

        .input-sm {
            width: 100%;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 0.55rem 0.8rem;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.2s;
            box-sizing: border-box;
        }
        .input-sm:focus { outline: none; border-color: var(--accent-blue); background: rgba(10,132,255,0.05); }

        .expected-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.45rem 0.7rem;
            margin-bottom: 0.35rem;
            border-radius: 7px;
            background: rgba(255,255,255,0.03);
        }

        .diff-badge {
            display: flex; align-items: center; justify-content: space-between;
            padding: 0.6rem 0.8rem;
            border-radius: 9px;
            border: 1px solid;
            margin-top: 0.6rem;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .saldo-final-box {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.85rem 1rem;
            border-radius: 10px;
            background: rgba(52,199,89,0.08);
            border: 1px solid rgba(52,199,89,0.3);
            margin-top: 0.75rem;
        }

        .btn-registrar {
            width: 100%;
            padding: 1rem;
            background: var(--accent-blue);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s;
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        }
        .btn-registrar:hover { opacity: 0.9; transform: translateY(-1px); }

        /* Historia */
        .history-panel { background: var(--bg-card); border-radius: 16px; border: 1px solid rgba(255,255,255,0.06); overflow: hidden; }
        .history-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 0.9rem 1.25rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.85rem; }
        th { font-weight: 600; color: var(--text-muted); background: rgba(0,0,0,0.15); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .dif-good { color: #34C759; font-weight: 700; }
        .dif-bad { color: #FF453A; font-weight: 700; }
        .btn-pdf { background: #FF3B30; padding: 0.5rem 1rem; font-size: 0.82rem; border-radius: 8px; border: none; color: white; cursor: pointer; font-weight: 700; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { active: 'cierres', user: user }) %>
    <main class="main-content">
        <div class="header" data-html2canvas-ignore="true">
            <h1>📋 Módulo de Cierres</h1>
            <div class="user-profile">
                <span><%= user.username %> (<%= user.rol %>)</span>
                <a href="/logout" style="color: #E3000F; margin-left: 1rem;">Salir</a>
            </div>
        </div>

        <div class="cierre-layout" id="exportable-area">

            <!-- ============ COLUMNA IZQUIERDA: FORMULARIO ============ -->
            <div data-html2canvas-ignore="true">
                <% if(user && user.rol === 'Cajero') { %>
                <div class="panel-cierre">

                    <!-- CABECERA -->
                    <div style="padding: 1.1rem 1.25rem; background: rgba(10,132,255,0.06); border-bottom: 1px solid rgba(10,132,255,0.15);">
                        <div style="font-size: 1rem; font-weight: 800; color: var(--accent-blue);">Arqueo de Caja — <%= tienda ? tienda.nombre : '' %></div>
                        <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem;">
                            Sistema espera: <strong style="color:#fff;">L <%= tienda ? Math.abs(tienda.efectivo_actual).toLocaleString('es-HN',{minimumFractionDigits:2}) : '0.00' %></strong> en caja hoy
                        </div>
                    </div>

                    <form action="/cierres/nuevo" method="POST" id="cierreForm">

                        <!-- ===================== PASO 0: REFERENCIA DEL SISTEMA ===================== -->
                        <% if(esperadoPorBanco && esperadoPorBanco.length > 0) { %>
                        <div class="step-block" style="background: rgba(255,255,255,0.01);">
                            <div class="step-header">
                                <div class="step-num" style="background:#333;">📊</div>
                                <span class="step-title" style="color: var(--text-muted);">Referencia del Sistema</span>
                            </div>
                            <% esperadoPorBanco.forEach(b => { %>
                            <div class="expected-row" style="border-left: 3px solid <%= b.banco_color || '#555' %>;">
                                <span style="font-size:0.8rem; color:<%= b.banco_color || '#aaa' %>; font-weight:600;"><%= b.banco_nombre %></span>
                                <span style="font-size:0.85rem; font-weight:700;">L <%= Math.abs(b.total_esperado||0).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                            </div>
                            <% }); %>
                            <div class="expected-row" style="background:rgba(10,132,255,0.08); border: 1px solid rgba(10,132,255,0.2); border-radius: 7px;">
                                <span style="font-size:0.82rem; font-weight:800; color:var(--accent-blue);">TOTAL ESPERADO</span>
                                <span style="font-size:0.95rem; font-weight:900; color:var(--accent-blue);">L <%= Math.abs(totalEsperado).toLocaleString('es-HN',{minimumFractionDigits:2}) %></span>
                            </div>
                        </div>
                        <% } %>

                        <!-- ===================== PASO 1: DECLARAR FÍSICO ===================== -->
                        <div class="step-block">
                            <div class="step-header">
                                <div class="step-num">1</div>
                                <span class="step-title">¿Cuánto tienes físico por banco?</span>
                            </div>
                            <% bancos.forEach(b => { %>
                            <div class="banco-row">
                                <div class="banco-label">
                                    <div class="banco-dot" style="background:<%= b.color||'#555' %>;"></div>
                                    <span style="color:<%= b.color||'#aaa' %>;"><%= b.nombre %></span>
                                </div>
                                <input type="text" name="banco_<%= b.id %>"
                                    class="input-sm money-input cierre-declarado"
                                    placeholder="L 0.00"
                                    data-banco-id="<%= b.id %>"
                                    oninput="calcularTotales()">
                            </div>
                            <% }) %>
                            <div class="banco-row">
                                <div class="banco-label">
                                    <div class="banco-dot" style="background:#555;"></div>
                                    <span style="color:#888;">Otros / Suelto</span>
                                </div>
                                <input type="text" name="banco_Otros"
                                    class="input-sm money-input cierre-declarado"
                                    placeholder="L 0.00"
                                    oninput="calcularTotales()">
                            </div>

                            <!-- RESUMEN AUTOMÁTICO CON DIFERENCIA -->
                            <div id="resumenDeclare" style="display:none; margin-top:0.75rem; padding:0.8rem; border-radius:10px; background:rgba(0,0,0,0.2); border:1px solid #2a2a2a;">
                                <div style="display:flex; justify-content:space-between; margin-bottom:0.4rem;">
                                    <span style="font-size:0.8rem; color:var(--text-muted);">Total declarado:</span>
                                    <span id="totalDeclarado" style="font-weight:700; font-size:0.9rem;">L 0.00</span>
                                </div>
                                <div style="display:flex; justify-content:space-between; padding-top:0.4rem; border-top:1px solid #2a2a2a;">
                                    <span style="font-size:0.8rem; font-weight:700;">Diferencia:</span>
                                    <span id="diferenciaLabel" style="font-weight:800; font-size:0.9rem;"></span>
                                </div>
                                <div id="estadoLabel" style="text-align:center; margin-top:0.5rem; font-size:0.75rem; font-weight:700; padding:0.3rem 0.5rem; border-radius:5px;"></div>
                            </div>
                        </div>

                        <!-- ===================== PASO 2: ENTREGA AL CONTADOR POR BANCO ===================== -->
                        <div class="step-block" style="background: rgba(108,45,145,0.04);">
                            <div class="step-header">
                                <div class="step-num" style="background:#6C2D91;">2</div>
                                <span class="step-title" style="color:#AF52DE;">¿Cuánto entregas al Contador?</span>
                            </div>
                            <p style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.75rem;">Específica por banco. Pon 0 si no entregas de ese banco hoy.</p>
                            <% bancos.forEach(b => { %>
                            <div class="banco-row">
                                <div class="banco-label">
                                    <div class="banco-dot" style="background:<%= b.color||'#555' %>;"></div>
                                    <span style="color:<%= b.color||'#aaa' %>;"><%= b.nombre %></span>
                                </div>
                                <input type="text" name="entrega_banco_<%= b.id %>"
                                    class="input-sm money-input cierre-entrega"
                                    placeholder="L 0.00"
                                    data-banco-id="<%= b.id %>"
                                    oninput="calcularSaldoFinal()">
                            </div>
                            <% }) %>
                            <div class="banco-row">
                                <div class="banco-label">
                                    <div class="banco-dot" style="background:#555;"></div>
                                    <span style="color:#888;">Otros</span>
                                </div>
                                <input type="text" name="entrega_banco_Otros"
                                    class="input-sm money-input cierre-entrega"
                                    placeholder="L 0.00"
                                    oninput="calcularSaldoFinal()">
                            </div>
                        </div>

                        <!-- ===================== PASO 3: RESUMEN Y SALDO FINAL ===================== -->
                        <div class="step-block" style="background: rgba(52,199,89,0.03);">
                            <div class="step-header">
                                <div class="step-num" style="background:#34C759;">3</div>
                                <span class="step-title" style="color:#34C759;">Resumen Final</span>
                            </div>

                            <div style="display:flex; justify-content:space-between; margin-bottom:0.4rem; font-size:0.82rem;">
                                <span style="color:var(--text-muted);">Total físico declarado:</span>
                                <span id="r_declarado" style="font-weight:700;">L 0.00</span>
                            </div>
                            <div style="display:flex; justify-content:space-between; margin-bottom:0.4rem; font-size:0.82rem;">
                                <span style="color:var(--text-muted);">Total entrega al contador:</span>
                                <span id="r_entrega" style="font-weight:700; color:#AF52DE;">L 0.00</span>
                            </div>
                            <div class="saldo-final-box">
                                <span style="font-size:0.85rem; font-weight:700; color:#34C759;">Saldo que queda mañana:</span>
                                <span id="saldoFinalLabel" style="font-size:1.1rem; font-weight:900; color:#34C759;">L 0.00</span>
                            </div>
                        </div>

                        <!-- OBSERVACIONES Y ENVÍO -->
                        <div class="step-block">
                            <label style="font-size:0.78rem; color:var(--text-muted); display:block; margin-bottom:0.4rem;">Observaciones (opcional)</label>
                            <input type="text" name="observaciones" class="input-sm" style="width:100%; margin-bottom:1rem;" placeholder="Ej: Faltaron L 5 por corte de luz">
                            <button type="submit" class="btn-registrar">✅ Registrar Cierre Oficial</button>
                        </div>

                    </form>
                </div>
                <% } else { %>
                <div class="panel-cierre">
                    <div style="padding: 2rem; text-align:center;">
                        <div style="font-size:2.5rem; margin-bottom:1rem;">📋</div>
                        <h2 style="font-size:1.1rem; color:var(--text-muted); margin-bottom:0.5rem;">Panel Admin / Contador</h2>
                        <p style="font-size:0.85rem; color:var(--text-muted);">Revisa el historial de cierres de todas las tiendas a la derecha.</p>
                    </div>
                </div>
                <% } %>
            </div>

            <!-- ============ COLUMNA DERECHA: HISTORIAL ============ -->
            <div class="history-panel">
                <div class="history-header">
                    <h2 style="font-size:1.1rem; font-weight:800;"><%= user && user.rol === 'Cajero' ? '🕘 Mis Cierres Registrados' : '📊 Reportes de Cierres (Global)' %></h2>
                    <button class="btn-pdf" onclick="generatePDF()" data-html2canvas-ignore="true">📄 Exportar PDF</button>
                </div>
                <div style="overflow-x:auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tienda</th>
                                <th>Cajero</th>
                                <th>Desglose Declarado</th>
                                <th>Teórico</th>
                                <th>Real</th>
                                <th>Diferencia</th>
                                <% if(user.rol === 'Admin') { %><th>Acciones</th><% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% cierres.forEach(c => { %>
                            <tr>
                                <td style="font-size:0.78rem; white-space:nowrap;"><%= new Date(c.fecha).toLocaleString('es-HN') %></td>
                                <td style="font-weight:600;"><%= c.tienda_nombre %></td>
                                <td><%= c.username %></td>
                                <td style="font-size:0.78rem; max-width:180px; line-height:1.5; color:var(--text-muted);">
                                    <%= c.desglose_bancos %>
                                    <% if(c.observaciones) { %><br><em style="color:#666;"><%= c.observaciones %></em><% } %>
                                </td>
                                <td style="font-weight:600;">L <%= c.saldo_teorico.toFixed(2) %></td>
                                <td style="font-weight:600;">L <%= c.saldo_real.toFixed(2) %></td>
                                <td class="<%= c.diferencia >= 0 ? (c.diferencia == 0 ? '' : 'dif-good') : 'dif-bad' %>">
                                    <%= c.diferencia > 0 ? '+' : '' %><%= c.diferencia.toFixed(2) %>
                                </td>
                                <% if(user.rol === 'Admin') { %>
                                    <td>
                                        <form action="/cierres/eliminar/<%= c.id %>" method="POST" onsubmit="return confirm('⚠️ ATENCIÓN: ¿Estás seguro que deseas deshacer y BORRAR este Cierre de Caja?\n\n- Se restaurará el saldo a la tienda.\n- La caja de la tienda volverá a su estado Abierta.\n- Se eliminarán las remesas pendientes asociadas a este cierre.');">
                                            <button type="submit" class="btn-pdf" style="background:#FF3B30; color:white; padding: 6px 12px;">↩ Revertir</button>
                                        </form>
                                    </td>
                                <% } %>
                            </tr>
                            <% }) %>
                            <% if(cierres.length === 0) { %>
                                <tr><td colspan="<%= user.rol === 'Admin' ? '8' : '7' %>" style="text-align:center; padding:3rem; color:var(--text-muted);">No hay cierres registrados aún.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script>
        const saldoEsperado = <%= tienda ? Math.abs(tienda.efectivo_actual) : 0 %>;
        let totalDeclaradoNum = 0;
        let totalEntregaNum = 0;

        function getVal(el) { return parseFloat((el.value || '0').replace(/,/g, '')) || 0; }
        const fmt = (n) => 'L ' + Math.abs(n).toLocaleString('es-HN', {minimumFractionDigits:2});

        function calcularTotales() {
            totalDeclaradoNum = 0;
            document.querySelectorAll('.cierre-declarado').forEach(inp => { totalDeclaradoNum += getVal(inp); });

            // Mostrar panel resumen
            const resumen = document.getElementById('resumenDeclare');
            resumen.style.display = totalDeclaradoNum > 0 ? 'block' : 'none';
            document.getElementById('totalDeclarado').textContent = fmt(totalDeclaradoNum);

            const diff = totalDeclaradoNum - saldoEsperado;
            const difEl = document.getElementById('diferenciaLabel');
            const estadoEl = document.getElementById('estadoLabel');

            if (Math.abs(diff) < 0.01) {
                difEl.textContent = 'L 0.00 ✓';
                difEl.style.color = '#34C759';
                estadoEl.textContent = '✅ CUADRA PERFECTO';
                estadoEl.style.cssText = 'background:rgba(52,199,89,0.1); color:#34C759; text-align:center; margin-top:0.5rem; font-size:0.75rem; font-weight:700; padding:0.3rem; border-radius:5px;';
            } else if (diff < 0) {
                difEl.textContent = '⚠ Faltan L ' + Math.abs(diff).toLocaleString('es-HN', {minimumFractionDigits:2});
                difEl.style.color = '#FF453A';
                estadoEl.textContent = 'FALTA EFECTIVO — Revisar antes de cerrar';
                estadoEl.style.cssText = 'background:rgba(255,69,58,0.1); color:#FF453A; text-align:center; margin-top:0.5rem; font-size:0.75rem; font-weight:700; padding:0.3rem; border-radius:5px;';
            } else {
                difEl.textContent = 'Sobran L ' + diff.toLocaleString('es-HN', {minimumFractionDigits:2});
                difEl.style.color = '#FF9F0A';
                estadoEl.textContent = '🔶 SOBRA EFECTIVO — Verificar origen';
                estadoEl.style.cssText = 'background:rgba(255,159,10,0.1); color:#FF9F0A; text-align:center; margin-top:0.5rem; font-size:0.75rem; font-weight:700; padding:0.3rem; border-radius:5px;';
            }

            calcularSaldoFinal();
        }

        function calcularSaldoFinal() {
            totalEntregaNum = 0;
            document.querySelectorAll('.cierre-entrega').forEach(inp => { totalEntregaNum += getVal(inp); });
            const final = Math.max(0, totalDeclaradoNum - totalEntregaNum);

            document.getElementById('r_declarado').textContent = fmt(totalDeclaradoNum);
            document.getElementById('r_entrega').textContent = fmt(totalEntregaNum);
            document.getElementById('saldoFinalLabel').textContent = fmt(final);
        }

        // Limpiar comas al enviar
        document.getElementById('cierreForm') && document.getElementById('cierreForm').addEventListener('submit', function() {
            this.querySelectorAll('.money-input').forEach(inp => {
                inp.value = (inp.value || '0').replace(/,/g, '');
            });
        });

        function generatePDF() {
            html2pdf().set({
                margin: 0.5,
                filename: 'Reporte_Cierres_Solucels.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'in', format: 'letter', orientation: 'landscape' }
            }).from(document.getElementById('exportable-area')).save();
        }
    </script>
    <script src="/js/money-formatter.js"></script>
</body>
</html>
