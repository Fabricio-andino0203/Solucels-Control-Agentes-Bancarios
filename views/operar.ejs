<!DOCTYPE html>
<html lang="es">
<head>
    <title>Operar Tienda (POS) - Solucels Control Agentes Bancarios</title>
    <%- include('partials/head') %>
</head>
<body class="pos-layout">
    <%- include('partials/sidebar', { active: 'dashboard', user: user }) %>

    <main class="main-content">
        <div class="header">
            <div>
                <h1 style="margin-bottom: 0.25rem;">Terminal de Operaciones POS</h1>
                <p style="color: var(--text-muted); font-size: 0.9rem;">Tienda: <strong><%= tienda.nombre %></strong></p>
            </div>
            <div style="display:flex; gap:10px;">
                <% if (user && user.rol === 'Cajero') { %>
                <button type="button" onclick="abrirModalCierre()" class="btn btn-warning" style="background: #E3A000; color:#fff; font-weight:bold; border:none; padding:10px 20px; border-radius:8px; cursor:pointer;">🔒 Corte de Caja</button>
                <% } %>
                <a href="/" class="btn btn-danger" style="background: #333;">X Cancelar</a>
            </div>
        </div>

        <form action="/transaccion" method="POST" id="posForm">
            <input type="hidden" name="tienda_id" value="<%= tienda.id %>">
            
            <div class="pos-container">
                <!-- PANEL IZQUIERDO: INPUTS -->
                <div class="pos-input-panel">
                    <div class="pos-display-label">Entrada de Monto</div>
                    <div class="pos-amount-display">
                        <input type="text" name="monto" class="money-input" id="posAmount" placeholder="0.00" required autofocus autocomplete="off">
                    </div>

                    <div style="margin-bottom: 2rem;">
                        <label class="pos-display-label">Referencia / Observación</label>
                        <input type="text" name="referencia" class="form-control" placeholder="Ej: Pago de cliente...">
                    </div>

                    <div class="pos-display-label">Seleccionar Banco</div>
                    <div class="bank-selector-grid">
                        <% bancos.forEach(function(b) { 
                             const isSelected = selectedBancoId && (b.id == selectedBancoId);
                        %>
                            <div class="bank-option-card <%= isSelected ? 'active' : '' %>" 
                                 onclick="updateBankSelection(this, '<%= b.id %>', '<%= (b.saldo_virtual || 0).toLocaleString('es-HN', {minimumFractionDigits: 2}) %>', '<%= (fisicoPorBanco[b.id] || 0).toLocaleString('es-HN', {minimumFractionDigits: 2}) %>')">
                                <div class="bank-dot" style="background: <%= b.color %>"></div>
                                <div class="bank-name"><%= b.nombre %></div>
                            </div>
                        <% }); %>
                    </div>
                    <input type="hidden" name="banco_id" id="bancoIdInput" value="<%= selectedBancoId || '' %>">
                    
                    <div class="bank-balance-preview" style="display: flex; justify-content: space-between; text-align: left;">
                        <div>
                            <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Saldo Virtual Disponible:</span>
                            <div id="virtualBalance" style="font-weight: 800; font-size: 1.4rem; color: var(--accent-blue);">
                                L <%= selectedBancoId ? (bancos.find(b => b.id == selectedBancoId)?.saldo_virtual || 0).toLocaleString('es-HN', {minimumFractionDigits: 2}) : '0.00' %>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Efectivo Disponible:</span>
                            <div id="physicalBalance" style="font-weight: 800; font-size: 1.4rem; color: #fff;">
                                L <%= selectedBancoId ? (fisicoPorBanco[selectedBancoId] || 0).toLocaleString('es-HN', {minimumFractionDigits: 2}) : '0.00' %>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-pos-submit" style="width: 100%; margin-top: 1rem;">Procesar Operación</button>
                </div>

                <!-- PANEL DERECHO: GRID DE OPERACIONES -->
                <div class="pos-ops-grid">
                    <label class="pos-op-btn <%= 1 ? '' : 'selected' %>" onclick="selectOp(this)">
                        <input type="radio" name="tipo" value="Depósito" required>
                        <span class="icon">📥</span>
                        <span class="label">DEPOSITO<br><small style="font-weight: 400; opacity: 0.7;">(+ Efec / - Banc)</small></span>
                    </label>

                    <label class="pos-op-btn" onclick="selectOp(this)">
                        <input type="radio" name="tipo" value="Retiro">
                        <span class="icon">📤</span>
                        <span class="label">RETIRO (+ COM)<br><small style="font-weight: 400; opacity: 0.7;">(- Efec / + Banc)</small></span>
                    </label>

                    <label class="pos-op-btn" onclick="selectOp(this)">
                        <input type="radio" name="tipo" value="Pago Servicio">
                        <span class="icon">🧾</span>
                        <span class="label">PAGO SERVICIOS<br><small style="font-weight: 400; opacity: 0.7;">(+ Efec / - Banc)</small></span>
                    </label>

                    <label class="pos-op-btn" onclick="selectOp(this)">
                        <input type="radio" name="tipo" value="Pago Caja Empresarial">
                        <span class="icon">🏢</span>
                        <span class="label">CAJA EMPRESARIAL<br><small style="font-weight: 400; opacity: 0.7;">(+ Efec / - Banc)</small></span>
                    </label>

                    <label class="pos-op-btn" onclick="selectOp(this)">
                        <input type="radio" name="tipo" value="Efectivo Entregado">
                        <span class="icon">💰</span>
                        <span class="label">EFECTIVO ENTREGADO<br><small style="font-weight: 400; opacity: 0.7;">(- Efec / En Auditoría)</small></span>
                    </label>

                    <!-- Botón especial: Gasto Bancario (abre modal propio) -->
                    <div class="pos-op-btn pos-op-special" onclick="abrirModalGasto()" style="border-color: rgba(255,159,10,0.4); cursor:pointer;">
                        <span class="icon">💸</span>
                        <span class="label">GASTO BANCARIO<br><small style="font-weight: 400; opacity: 0.7;">(- Saldo Virtual)</small></span>
                    </div>

                    <!-- Botón especial: Traspaso Efectivo (abre modal propio) -->
                    <div class="pos-op-btn pos-op-special" onclick="abrirModalTraspaso()" style="border-color: rgba(48,209,88,0.4); cursor:pointer;">
                        <span class="icon">🔄</span>
                        <span class="label">TRASPASO EFECTIVO<br><small style="font-weight: 400; opacity: 0.7;">(Reasignar por Banco)</small></span>
                    </div>
                </div>
            </div>
        </form>
    </main>

    <!-- ========== MODAL: GASTO BANCARIO ========== -->
    <div id="modalGasto" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:center;">
        <div style="background:var(--bg-card); width:100%; max-width:460px; border-radius:16px; border:1px solid rgba(255,159,10,0.3); padding:0; overflow:hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.6);">
            <div style="padding:1.5rem; background:rgba(255,159,10,0.08); border-bottom:1px solid rgba(255,159,10,0.2); display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h2 style="color:#FF9F0A; margin:0; font-size:1.3rem;">💸 Gasto Bancario</h2>
                    <p style="margin:0.2rem 0 0 0; font-size:0.82rem; color:var(--text-muted);">Registra un gasto y descuenta del saldo virtual del banco.</p>
                </div>
                <button onclick="cerrarModalGasto()" style="background:none; border:none; color:#fff; font-size:1.5rem; cursor:pointer; padding:4px;">&times;</button>
            </div>
            <form action="/operar/gasto-bancario" method="POST" style="padding:1.5rem;" id="formGastoPOS" onsubmit="return limpiarMonedaGasto()">
                <input type="hidden" name="tienda_id" value="<%= tienda.id %>">

                <div style="margin-bottom:1.2rem;">
                    <label style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem;">Banco</label>
                    <select name="banco_id" class="form-control" required style="background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.8rem; border-radius:8px; width:100%;">
                        <option value="">-- Seleccionar Banco --</option>
                        <% bancos.forEach(b => { %>
                            <option value="<%= b.id %>"><%= b.nombre %></option>
                        <% }) %>
                    </select>
                </div>

                <div style="margin-bottom:1.2rem;">
                    <label style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem;">Monto (L)</label>
                    <input type="text" name="monto" id="gastoMontoPOS" class="money-input form-control" placeholder="0.00" required style="background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.8rem; border-radius:8px; width:100%; font-size:1.2rem; font-weight:800;">
                </div>

                <div style="margin-bottom:1.2rem;">
                    <label style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem;">Categoría</label>
                    <select name="categoria" class="form-control" required style="background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.8rem; border-radius:8px; width:100%;">
                        <option value="Servicios">Servicios</option>
                        <option value="Suministros">Suministros</option>
                        <option value="Transporte">Transporte</option>
                        <option value="Personal">Personal</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>

                <div style="margin-bottom:1.5rem;">
                    <label style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem;">Descripción (Opcional)</label>
                    <input type="text" name="descripcion" class="form-control" placeholder="Ej: Pago de servicio eléctrico..." style="background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.8rem; border-radius:8px; width:100%;">
                </div>

                <div style="display:flex; gap:1rem;">
                    <button type="button" onclick="cerrarModalGasto()" style="flex:1; padding:0.9rem; border-radius:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1); color:#fff; cursor:pointer; font-size:0.95rem;">Cancelar</button>
                    <button type="submit" style="flex:2; padding:0.9rem; border-radius:8px; background:linear-gradient(135deg,#FF9F0A,#FF6B00); border:none; color:#fff; font-weight:800; font-size:0.95rem; cursor:pointer; letter-spacing:0.5px; box-shadow:0 4px 15px rgba(255,159,10,0.3);">Registrar Gasto</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ========== MODAL: TRASPASO EFECTIVO ========== -->
    <div id="modalTraspaso" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:center;">
        <div style="background:var(--bg-card); width:100%; max-width:480px; border-radius:16px; border:1px solid rgba(48,209,88,0.3); padding:0; overflow:hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.6);">
            <div style="padding:1.5rem; background:rgba(48,209,88,0.08); border-bottom:1px solid rgba(48,209,88,0.2); display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h2 style="color:#30D158; margin:0; font-size:1.3rem;">🔄 Traspaso de Efectivo</h2>
                    <p style="margin:0.2rem 0 0 0; font-size:0.82rem; color:var(--text-muted);">Reasigna efectivo de un banco a otro dentro de esta tienda. El total no cambia.</p>
                </div>
                <button onclick="cerrarModalTraspaso()" style="background:none; border:none; color:#fff; font-size:1.5rem; cursor:pointer; padding:4px;">&times;</button>
            </div>
            <form action="/operar/traspaso-efectivo" method="POST" style="padding:1.5rem;" id="formTraspasoPOS" onsubmit="return limpiarMonedaTraspaso()">
                <input type="hidden" name="tienda_id" value="<%= tienda.id %>">

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.2rem;">
                    <div>
                        <label style="font-size:0.8rem; color:#FF453A; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem; font-weight:700;">Banco Origen 📤</label>
                        <select name="banco_origen_id" id="traspOrigenSel" class="form-control" required style="background:rgba(255,69,58,0.05); border:1px solid rgba(255,69,58,0.3); color:#fff; padding:0.8rem; border-radius:8px; width:100%;">
                            <option value="">-- Seleccionar --</option>
                            <% bancos.forEach(b => { %>
                                <option value="<%= b.id %>" data-fisico="<%= (fisicoPorBanco[b.id] || 0).toFixed(2) %>"><%= b.nombre %> (L <%= (fisicoPorBanco[b.id] || 0).toLocaleString('es-HN', {minimumFractionDigits:2}) %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div>
                        <label style="font-size:0.8rem; color:#30D158; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem; font-weight:700;">Banco Destino 📥</label>
                        <select name="banco_destino_id" class="form-control" required style="background:rgba(48,209,88,0.05); border:1px solid rgba(48,209,88,0.3); color:#fff; padding:0.8rem; border-radius:8px; width:100%;">
                            <option value="">-- Seleccionar --</option>
                            <% bancos.forEach(b => { %>
                                <option value="<%= b.id %>"><%= b.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); border-radius:10px; padding:1rem; margin-bottom:1.2rem; font-size:0.85rem; color:var(--text-muted);">
                    Efectivo disponible en banco origen: <strong id="traspOrigenDisponible" style="color:#fff;">L 0.00</strong>
                </div>

                <div style="margin-bottom:1.2rem;">
                    <label style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem;">Monto a Traspasar (L)</label>
                    <input type="text" name="monto" id="traspasoMontoPOS" class="money-input form-control" placeholder="0.00" required style="background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.8rem; border-radius:8px; width:100%; font-size:1.2rem; font-weight:800;">
                </div>

                <div style="margin-bottom:1.5rem;">
                    <label style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:0.5rem;">Referencia (Opcional)</label>
                    <input type="text" name="referencia" class="form-control" placeholder="Ej: Traspaso para pago de nómina..." style="background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.8rem; border-radius:8px; width:100%;">
                </div>

                <div style="display:flex; gap:1rem;">
                    <button type="button" onclick="cerrarModalTraspaso()" style="flex:1; padding:0.9rem; border-radius:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1); color:#fff; cursor:pointer; font-size:0.95rem;">Cancelar</button>
                    <button type="submit" style="flex:2; padding:0.9rem; border-radius:8px; background:linear-gradient(135deg,#30D158,#00A36C); border:none; color:#fff; font-weight:800; font-size:0.95rem; cursor:pointer; letter-spacing:0.5px; box-shadow:0 4px 15px rgba(48,209,88,0.3);">Registrar Traspaso</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL DE CORTE DE CAJA -->
    <% if (user && user.rol === 'Cajero') { %>
    <div id="modalCierre" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:flex-start; overflow-y:auto; padding:2rem;">
        <div style="background:var(--bg-card); width:100%; max-width:900px; border-radius:16px; border:1px solid rgba(255,255,255,0.1); position:relative; overflow:hidden;">
            <button type="button" onclick="cerrarModalCierre()" style="position:absolute; top:1.2rem; right:1.5rem; background:none; border:none; color:#fff; font-size:1.5rem; cursor:pointer;">&times;</button>
            <div style="padding:1.5rem; background:rgba(227,160,0,0.1); border-bottom:1px solid rgba(227,160,0,0.2);">
                <h2 style="color:#E3A000; margin:0; font-size:1.4rem;">🔒 Corte de Caja Oficial</h2>
                <p style="margin:0.2rem 0 0 0; font-size:0.85rem; color:var(--text-muted);">Realiza el arqueo y cierre de la caja declarando el físico y la entrega al contador.</p>
                <div style="margin-top:0.5rem; font-size: 0.9rem; color: #fff;">
                    Sistema espera: <strong style="color:var(--accent-blue);">L <%= tienda ? Math.abs(tienda.efectivo_actual).toLocaleString('es-HN',{minimumFractionDigits:2}) : '0.00' %></strong> en caja
                </div>
            </div>
            
            <form action="/cierres/nuevo" method="POST" id="cierreFormModal" style="padding:1.5rem;">
                <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                    
                    <!-- PASO 1 -->
                    <div style="flex: 1; min-width: 300px;">
                        <div style="font-weight:bold; font-size:1.1rem; margin-bottom:1rem; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:0.5rem; color: #E3A000;">1. Declarar Efectivo Físico</div>
                        <p style="font-size: 0.8rem; color: #888; margin-bottom: 1rem;">Ingresa cuánto dinero físico contaste en caja.</p>
                        <% 
                        let totalEsperadoBancos = 0;
                        bancos.forEach(b => { 
                            let esperadoB = fisicoPorBanco[b.id] || 0;
                            totalEsperadoBancos += esperadoB;
                        %>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
                            <div style="display:flex; flex-direction:column;">
                                <span style="color:<%= b.color || '#aaa' %>; font-size:0.95rem; font-weight:600;"><%= b.nombre %></span>
                                <span style="font-size:0.75rem; color:var(--text-muted);">Esperado: <strong>L <%= esperadoB.toLocaleString('es-HN', {minimumFractionDigits:2}) %></strong></span>
                            </div>
                            <input type="text" name="banco_<%= b.id %>" data-banco-nombre="<%= b.nombre %>" data-banco-color="<%= b.color %>" class="form-control money-input close-declare" style="width:130px; background:rgba(0,0,0,0.3); color:#fff; border:1px solid rgba(255,255,255,0.1);" placeholder="L 0.00">
                        </div>
                        <% }); %>
                        <% 
                        let totalGeneralEsperado = tienda ? Math.abs(tienda.efectivo_actual) : 0;
                        let esperadoOtros = totalGeneralEsperado - totalEsperadoBancos;
                        if (esperadoOtros < 0) esperadoOtros = 0; 
                        %>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
                            <div style="display:flex; flex-direction:column;">
                                <span style="color:#888; font-size:0.95rem; font-weight:600;">Otros / Suelto</span>
                                <span style="font-size:0.75rem; color:var(--text-muted);">Esperado: <strong>L <%= esperadoOtros.toLocaleString('es-HN', {minimumFractionDigits:2}) %></strong></span>
                            </div>
                            <input type="text" name="banco_Otros" data-banco-nombre="Otros / Suelto" data-banco-color="#888" class="form-control money-input close-declare" style="width:130px; background:rgba(0,0,0,0.3); color:#fff; border:1px solid rgba(255,255,255,0.1);" placeholder="L 0.00">
                        </div>
                    </div>

                    <!-- PASO 2 -->
                    <div style="flex: 1; min-width: 300px;">
                        <div style="font-weight:bold; font-size:1.1rem; margin-bottom:1rem; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:0.5rem; color: #0a84ff;">2. Entrega a Tesorería</div>
                        <p style="font-size: 0.8rem; color: #888; margin-bottom: 1rem;">Ingresa cuánto efectivo envías al Contador.</p>
                        <% bancos.forEach(b => { %>
                        <div style="display:flex; justify-content:space-between; align-items:center; height: 42px; margin-bottom:0.75rem;">
                            <span style="color:<%= b.color || '#aaa' %>; font-size:0.95rem; font-weight:600;"><%= b.nombre %></span>
                            <input type="text" name="entrega_banco_<%= b.id %>" class="form-control money-input close-delivery" style="width:130px; background:rgba(10,132,255,0.1); color:#fff; border:1px solid rgba(10,132,255,0.3);" placeholder="L 0.00">
                        </div>
                        <% }); %>
                        <div style="display:flex; justify-content:space-between; align-items:center; height: 42px; margin-bottom:0.75rem;">
                            <span style="color:#888; font-size:0.95rem; font-weight:600;">Otros / Suelto</span>
                            <input type="text" name="entrega_banco_Otros" class="form-control money-input close-delivery" style="width:130px; background:rgba(10,132,255,0.1); color:#fff; border:1px solid rgba(10,132,255,0.3);" placeholder="L 0.00">
                        </div>
                    </div>
                </div>

                <div style="border-top: 1px solid rgba(255,255,255,0.05); margin-top: 1rem; padding-top: 1.5rem;">
                    
                    <!-- RESUMEN AUTOMATICO -->
                    <div id="resumenDeclareModal" style="display:none; padding:1.25rem; border-radius:12px; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.05); margin-bottom:1.5rem;">
                        <div style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">
                            <span style="color:var(--text-muted); font-size:0.9rem;">Total Efectivo Declarado:</span>
                            <span id="totalDeclaradoModal" style="font-weight:bold; font-size:1.1rem; color:#fff;">L 0.00</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid rgba(255,255,255,0.05); padding-top:0.75rem; margin-top:0.5rem;">
                            <span style="font-size:0.9rem; font-weight:bold; color:#aaa;">Discrepancia del Día:</span>
                            <div>
                                <span id="diferenciaLabelModal" style="font-weight:bold; font-size:1.1rem;"></span>
                            </div>
                        </div>
                        <div id="estadoLabelModal" style="margin-top:0.75rem; font-size:0.85rem; font-weight:bold; text-align:center; padding:0.6rem; border-radius:8px;"></div>
                        <p id="sobranteInfo" style="display:none; font-size: 0.75rem; color:#888; text-align:center; margin-top: 0.5rem;">* El excedente será automáticamente inyectado al saldo de la tienda para cuadrar el balance físico con el global.</p>
                    </div>

                    <!-- RESUMEN FINAL -->
                    <div style="background:rgba(52,199,89,0.08); border:1px solid rgba(52,199,89,0.3); padding:1rem; border-radius:10px; margin-bottom:1.5rem;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-size:1rem; font-weight:bold; color:#34C759;">Saldo que queda para mañana:</span>
                            <span id="saldoFinalCierreModal" style="font-size:1.4rem; font-weight:bold; color:#34C759;">L 0.00</span>
                        </div>
                        <div id="saldoFinalPorBancoContainer" style="margin-top: 1rem; display: none;"></div>
                    </div>

                    <div style="margin-bottom:1.5rem;">
                        <label style="font-size:0.9rem; color:var(--text-muted); display:block; margin-bottom:0.5rem;">Observaciones (Opcional)</label>
                        <input type="text" name="observaciones" class="form-control" style="background:rgba(0,0,0,0.3); color:#fff; border:1px solid rgba(255,255,255,0.1);" placeholder="Ej: Faltaron L 5 por pago de botellón de agua...">
                    </div>

                    <button type="submit" class="btn btn-warning" style="width:100%; background:#E3A000; color:#fff; font-size:1.15rem; padding:15px; font-weight:bold; border:none; border-radius:8px; text-transform: uppercase; letter-spacing: 1px; box-shadow: 0 4px 15px rgba(227,160,0,0.3);">✅ Registrar Cierre Oficial</button>
                </div>
            </form>
        </div>
    </div>
    <% } %>

    <script>
        function updateBankSelection(element, bancoId, virtualBal, fisicoBal) {
            document.querySelectorAll('.bank-option-card').forEach(p => p.classList.remove('active'));
            element.classList.add('active');
            document.getElementById('bancoIdInput').value = bancoId;
            document.getElementById('virtualBalance').innerText = 'L ' + virtualBal;
            document.getElementById('physicalBalance').innerText = 'L ' + fisicoBal;
        }

        function selectOp(element) {
            document.querySelectorAll('.pos-op-btn').forEach(btn => btn.classList.remove('selected'));
            element.classList.add('selected');
            element.querySelector('input').checked = true;
        }

        // Formateador de moneda en tiempo real con COMAS de miles
        // IMPORTANTE: El formateador corre PRIMERO y luego llama resumenCierreModal()
        // para que el resumen siempre lea el valor ya formateado correctamente.
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('money-input')) {
                let value = e.target.value.replace(/\D/g, "");
                if (value === "") {
                    e.target.value = "";
                    // Si es campo de cierre, actualizar resumen
                    if (e.target.classList.contains('close-declare') || e.target.classList.contains('close-delivery')) {
                        resumenCierreModal();
                    }
                    return;
                }
                
                // Convertimos a número con 2 decimales
                let floatValue = parseFloat(value) / 100;
                
                // Formateamos con comas y punto decimal 
                e.target.value = new Intl.NumberFormat('en-US', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                }).format(floatValue);

                // Después de formatear, actualizar el resumen del cierre si aplica
                if (e.target.classList.contains('close-declare') || e.target.classList.contains('close-delivery')) {
                    resumenCierreModal();
                }
            }
        });

        // Al enviar el formulario cargado, debemos limpiar las comas para que sea un número válido para el backend
        document.getElementById('posForm').addEventListener('submit', function(e) {
            const bancoId = document.getElementById('bancoIdInput').value;
            const opSeleccionada = document.querySelector('input[name="tipo"]:checked');
            
            if (opSeleccionada && !bancoId) {
                e.preventDefault();
                alert('⚠️ Debe seleccionar un banco antes de procesar la operación.');
                return;
            }

            const amountInput = document.getElementById('posAmount');
            amountInput.value = amountInput.value.replace(/,/g, ""); 
        });

        document.getElementById('cierreFormModal').addEventListener('submit', function(e) {
            this.querySelectorAll('.money-input').forEach(inp => {
                inp.value = (inp.value || '0').replace(/[^0-9.-]+/g, '');
            });
        });

        // ===== FUNCIONES MODALES NUEVOS =====
        function abrirModalGasto() {
            document.getElementById('modalGasto').style.display = 'flex';
        }
        function cerrarModalGasto() {
            document.getElementById('modalGasto').style.display = 'none';
        }
        function abrirModalTraspaso() {
            document.getElementById('modalTraspaso').style.display = 'flex';
        }
        function cerrarModalTraspaso() {
            document.getElementById('modalTraspaso').style.display = 'none';
        }

        // Limpiar monedas antes de enviar Gasto
        function limpiarMonedaGasto() {
            const inp = document.getElementById('gastoMontoPOS');
            inp.value = (inp.value || '0').replace(/,/g, '');
            return true;
        }
        // Limpiar monedas antes de enviar Traspaso
        function limpiarMonedaTraspaso() {
            const inp = document.getElementById('traspasoMontoPOS');
            inp.value = (inp.value || '0').replace(/,/g, '');
            return true;
        }

        // Mostrar disponible del banco origen al cambiar el select de traspaso
        document.getElementById('traspOrigenSel').addEventListener('change', function() {
            const opt = this.options[this.selectedIndex];
            const fisico = parseFloat(opt.getAttribute('data-fisico') || '0');
            document.getElementById('traspOrigenDisponible').textContent = 'L ' + fisico.toLocaleString('es-HN', { minimumFractionDigits: 2 });
        });

        // Cerrar modales al hacer click fuera
        window.addEventListener('click', function(e) {
            if (e.target === document.getElementById('modalGasto')) cerrarModalGasto();
            if (e.target === document.getElementById('modalTraspaso')) cerrarModalTraspaso();
        });


        // LOGICA DE CIERRE DE CAJA
        const saldoCajaEsperado = <%= tienda ? Math.abs(tienda.efectivo_actual) : 0 %>;
        function getModalVal(el) { 
            if (!el || !el.value) return 0;
            // Limpieza estricta: quitamos comas y todo lo que no sea dígito o punto
            let clean = el.value.toString().replace(/,/g, '').replace(/[^\d.]/g, '');
            let val = parseFloat(clean);
            return isNaN(val) ? 0 : Math.round(val * 100) / 100;
        }
        
        function resumenCierreModal() {
            let trDeclarado = 0;
            let trEntregaTotal = 0;
            let htmlDesglose = '';

            let bancosInputs = document.querySelectorAll('.close-declare');
            let bancosEntregas = document.querySelectorAll('.close-delivery');

            // Sumamos el total declarado
            bancosInputs.forEach(inp => { trDeclarado += getModalVal(inp); });
            // Sumamos las entregas
            bancosEntregas.forEach(inp => { trEntregaTotal += getModalVal(inp); });

            trDeclarado = Math.round(trDeclarado * 100) / 100;
            trEntregaTotal = Math.round(trEntregaTotal * 100) / 100;

            // Generamos el desglose visual para el saldo de mañana
            for(let i=0; i<bancosInputs.length; i++) {
                let declInp = bancosInputs[i];
                let entreInp = bancosEntregas[i];
                
                let bName = declInp.getAttribute('data-banco-nombre');
                let bColor = declInp.getAttribute('data-banco-color');
                
                let valDec = getModalVal(declInp);
                let valEnt = getModalVal(entreInp);
                let rest = Math.max(0, valDec - valEnt);
                
                if(rest > 0 || valDec > 0) {
                    htmlDesglose += `
                        <div style="display:flex; justify-content:space-between; font-size:0.85rem; margin-top:0.5rem; padding-top:0.5rem; border-top:1px dashed rgba(52,199,89,0.3);">
                            <span style="color:${bColor || '#aaa'}; font-weight:600;">Saldo en ${bName}:</span>
                            <span style="color:#fff; font-weight:bold;">L ${rest.toLocaleString('es-HN', {minimumFractionDigits:2})}</span>
                        </div>
                    `;
                }
            }

            const resumen = document.getElementById('resumenDeclareModal');
            resumen.style.display = 'block';
            document.getElementById('totalDeclaradoModal').textContent = 'L ' + trDeclarado.toLocaleString('es-HN', {minimumFractionDigits:2});

            const diff = Math.round((trDeclarado - saldoCajaEsperado) * 100) / 100;
            const difEl = document.getElementById('diferenciaLabelModal');
            const estEl = document.getElementById('estadoLabelModal');

            if (Math.abs(diff) < 0.01) {
                difEl.textContent = 'L 0.00 ✓'; difEl.style.color = '#34C759';
                estEl.textContent = '✅ CUADRA PERFECTO'; estEl.style.cssText = 'background:rgba(52,199,89,0.1); color:#34C759; text-align:center; margin-top:0.5rem; padding:8px; border-radius:5px; border: 1px solid rgba(52,199,89,0.2);';
                document.getElementById('sobranteInfo').style.display = 'none';
            } else if (diff < 0) {
                difEl.textContent = '⚠ Faltan L ' + Math.abs(diff).toLocaleString('es-HN', {minimumFractionDigits:2}); difEl.style.color = '#FF453A';
                estEl.textContent = '🔻 FALTA EFECTIVO — Se descontará automáticamente de la caja'; estEl.style.cssText = 'background:rgba(255,69,58,0.1); color:#FF453A; text-align:center; margin-top:0.5rem; padding:8px; border-radius:5px; border: 1px solid rgba(255,69,58,0.2);';
                document.getElementById('sobranteInfo').style.display = 'none';
            } else {
                difEl.textContent = 'Sobran L ' + diff.toLocaleString('es-HN', {minimumFractionDigits:2}); difEl.style.color = '#0a84ff';
                estEl.textContent = '🔶 SOBRA EFECTIVO — Ingresará a la caja'; estEl.style.cssText = 'background:rgba(10,132,255,0.1); color:#0a84ff; text-align:center; margin-top:0.5rem; padding:8px; border-radius:5px; border: 1px solid rgba(10,132,255,0.2);';
                document.getElementById('sobranteInfo').style.display = 'block';
            }

            const containerList = document.getElementById('saldoFinalPorBancoContainer');
            if (htmlDesglose.length > 0) {
                containerList.innerHTML = htmlDesglose;
                containerList.style.display = 'block';
            } else {
                containerList.innerHTML = '';
                containerList.style.display = 'none';
            }

            const finalSaldo = Math.max(0, trDeclarado - trEntregaTotal);
            document.getElementById('saldoFinalCierreModal').textContent = 'L ' + finalSaldo.toLocaleString('es-HN', {minimumFractionDigits:2});
        }

        function abrirModalCierre() { document.getElementById('modalCierre').style.display = 'flex'; }
        function cerrarModalCierre() { document.getElementById('modalCierre').style.display = 'none'; }
        
        // 5:55 PM Reminder Logic
        <% if (user && user.rol === 'Cajero') { %>
        setInterval(() => {
            const d = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Tegucigalpa' }));
            if (d.getHours() === 17 && d.getMinutes() === 55) {
                if (localStorage.getItem('alerta_cierre') !== d.toDateString()) {
                    localStorage.setItem('alerta_cierre', d.toDateString());
                    // Mostrar alerta visual
                    const alertBox = document.createElement('div');
                    alertBox.innerHTML = `
                        <div style="position:fixed; top:20px; left:50%; transform:translateX(-50%); background:var(--accent-blue); color:#fff; padding:1.25rem 2.5rem; border-radius:12px; z-index:10000; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border: 2px solid rgba(255,255,255,0.2); display:flex; align-items:center; gap:15px; font-family:'Inter'; text-align:center; animation: dropDown 0.5s ease forwards;">
                            <span style="font-size: 2rem;">⏰</span>
                            <div>
                                <h3 style="margin:0 0 5px 0; font-size:1.1rem; font-weight:800; letter-spacing:0.5px;">¡RECORDATORIO IMPORTANTE!</h3>
                                <p style="margin:0; font-size:0.95rem;">Son las <strong>5:55 PM</strong>. Por favor, asegúrate de realizar el <strong style="color:#FFD60A;">Corte de Caja Oficial</strong>.</p>
                            </div>
                            <button onclick="this.parentElement.remove()" style="background:rgba(0,0,0,0.3); border:none; color:white; font-size:1.5rem; cursor:pointer; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-left:15px; transition:0.2s;">&times;</button>
                        </div>
                        <style>@keyframes dropDown { from{top:-100px;} to{top:20px;} }</style>
                    `;
                    document.body.appendChild(alertBox);
                    
                    // Reproducir sonido simple
                    try {
                        const audio = new Audio('data:audio/wav;base64,UklGRl9vT19XQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YU');
                        audio.play();
                    } catch(e) {}
                }
            }
        }, 30000); // Revisar cada 30 segundos
        <% } %>
    </script>
    <style>
        /* Ajuste fino para la vista actual */
        .pos-layout .main-content { overflow-y: hidden; }

        .bank-selector-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 10px;
            margin-bottom: 1.5rem;
        }

        .bank-option-card {
            background: #1a1a1a;
            border: 1px solid #333;
            padding: 12px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .bank-option-card:hover {
            border-color: #555;
            background: #252525;
        }

        .bank-option-card.active {
            border-color: var(--accent-blue);
            background: rgba(10, 132, 255, 0.1);
        }

        .bank-option-card .bank-name {
            font-size: 0.85rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .bank-balance-preview {
            background: rgba(255, 255, 255, 0.03);
            padding: 1.25rem;
            border-radius: 16px;
            border: 1px solid #222;
            margin-bottom: 2rem;
            text-align: center;
        }

        /* Botones especiales del POS que abren modales propios */
        .pos-op-special {
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 1.2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            text-align: center;
            transition: all 0.2s;
            user-select: none;
        }
        .pos-op-special:hover {
            background: rgba(255,255,255,0.05);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        }
        .pos-op-special .icon { font-size: 1.8rem; }
        .pos-op-special .label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; line-height: 1.3; }
    </style>
</body>
</html>
