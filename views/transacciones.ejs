<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Transacciones - Solucels Control Agentes Bancarios</title>
    <style>
        .filter-bar {
            display: flex; gap: 1rem; margin-bottom: 2rem; background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 12px; flex-wrap: wrap; border: 1px solid rgba(255,255,255,0.05); align-items: center; box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        .filter-control {
            background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 0.75rem 1rem; border-radius: 8px; font-family: 'Inter'; flex: 1; min-width: 150px; outline: none; transition: 0.3s; font-size: 0.95rem;
        }
        .filter-control:focus { border-color: var(--accent-blue); box-shadow: 0 0 0 2px rgba(10,132,255,0.2); }
        .filter-label { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.4rem; display: block; }
        
        .tx-container {
            background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        table { width: 100%; border-collapse: collapse; }
        thead { background: rgba(0,0,0,0.3); }
        th, td { padding: 1.2rem 1rem; text-align: left; font-size: 0.95rem; border-bottom: 1px solid rgba(255,255,255,0.03); }
        th { font-weight: 700; color: #aaa; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; }
        tbody tr { transition: 0.2s; }
        tbody tr:hover { background: rgba(10,132,255,0.05); }
        
        .type-badge { padding: 0.3rem 0.6rem; border-radius: 6px; font-size: 0.8rem; font-weight: 700; display: inline-block; letter-spacing: 0.5px; }
        .type-ingreso { background: rgba(52, 199, 89, 0.15); color: #34c759; border: 1px solid rgba(52, 199, 89, 0.2); }
        .type-retiro { background: rgba(255, 69, 58, 0.15); color: #ff453a; border: 1px solid rgba(255, 69, 58, 0.2); }
        .type-pago { background: rgba(10, 132, 255, 0.15); color: #0a84ff; border: 1px solid rgba(10, 132, 255, 0.2); }
        .type-gasto { background: rgba(255, 159, 10, 0.15); color: #ff9f0a; border: 1px solid rgba(255, 159, 10, 0.2); }
        .type-deposito { background: rgba(191, 90, 242, 0.15); color: #bf5af2; border: 1px solid rgba(191, 90, 242, 0.2); }
        
        .btn-action { background: none; border: none; cursor: pointer; padding: 0.5rem; border-radius: 6px; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; }
        .btn-edit { color: #0a84ff; background: rgba(10,132,255,0.1); }
        .btn-edit:hover { background: rgba(10,132,255,0.2); transform: scale(1.05); }
        .btn-delete { color: #ff453a; background: rgba(255,69,58,0.1); }
        .btn-delete:hover { background: rgba(255,69,58,0.2); transform: scale(1.05); }
        
        /* Modal Styles */
        .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); }
        .modal-content { background: var(--bg-card); margin: 5% auto; padding: 2.5rem; border-radius: 20px; width: 90%; max-width: 450px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
        .modal-header { font-size: 1.3rem; font-weight: 800; margin-bottom: 1.5rem; color: #fff; display: flex; justify-content: space-between; align-items: center; }
        .close-modal { color: #888; cursor: pointer; font-size: 1.8rem; transition: 0.2s; }
        .close-modal:hover { color: #ff453a; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { active: 'transacciones', user: user }) %>
    <main class="main-content">
        <div class="header">
            <h1>Registro Histórico</h1>
            <div class="user-profile">
                <span><%= user.username %> (<%= user.rol %>)</span>
                <a href="/logout" style="color: #E3000F; margin-left: 1rem;">Salir</a>
            </div>
        </div>

        <div class="filter-bar">
            <% if(user && user.rol !== 'Cajero') { %>
                <div style="flex: 1;">
                    <span class="filter-label">Tienda</span>
                    <select class="filter-control" id="filt-tienda" style="width: 100%;">
                        <option value="">Todas las Tiendas</option>
                        <% tiendas.forEach(t => { %> <option value="<%= t.nombre %>"><%= t.nombre %></option> <% }) %>
                    </select>
                </div>
            <% } %>
            <div style="flex: 1;">
                <span class="filter-label">Tipo de Operación</span>
                <select class="filter-control" id="filt-tipo" style="width: 100%;" onchange="aplicarFiltroTipo(this.value)">
                    <option value="" <%= tipoFiltro === '' ? 'selected' : '' %>>Todas las Operaciones</option>
                    <% tipos.forEach(t => { %>
                        <option value="<%= t %>" <%= tipoFiltro === t ? 'selected' : '' %>><%= t %></option>
                    <% }) %>
                </select>
            </div>
            <div style="flex: 1;">
                <span class="filter-label">Banco</span>
                <select class="filter-control" id="filt-banco" style="width: 100%;">
                    <option value="">Todos los Bancos</option>
                    <% bancos.forEach(b => { %> <option value="<%= b.nombre %>"><%= b.nombre %></option> <% }) %>
                </select>
            </div>
            <div style="flex: 1;">
                <span class="filter-label">Fecha de Operación</span>
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <input type="date" class="filter-control" id="filt-fecha" style="width: 100%;">
                    <button class="btn btn-primary" onclick="document.getElementById('filt-fecha').value=''; filterTable();" style="padding: 0.75rem 1rem; border-radius: 8px; font-weight: bold; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: #fff;" title="Ver todas las fechas">Todo</button>
                </div>
            </div>
        </div>

        <div class="tx-container" style="overflow-x: auto;">
            <table id="txTable">
                <thead>
                    <tr>
                        <th>Fecha/Hora</th>
                        <th>Tienda</th>
                        <th>Usuario</th>
                        <th>Banco</th>
                        <th>Tipo</th>
                        <th>Caja (L)</th>
                        <th>Banco (L)</th>
                        <th>Referencia</th>
                        <% if(user.rol !== 'Cajero') { %><th style="text-align: right;">Acciones</th><% } %>
                    </tr>
                </thead>
                <tbody>
                    <% transacciones.forEach(tx => { 
                        let cls = '';
                        if(tx.tipo === 'Ingreso' || tx.tipo === 'Sobrante' || tx.tipo.includes('Resurtido') || tx.tipo.includes('Traspaso Entrada')) cls='type-ingreso';
                        else if(tx.tipo === 'Retiro' || tx.tipo === 'Faltante' || tx.tipo.includes('Traspaso Salida')) cls='type-retiro';
                        else if(tx.tipo === 'Pago Servicio') cls='type-pago';
                        else if(tx.tipo.includes('Gasto')) cls='type-gasto';
                        else cls='type-deposito';
                    %>
                    <% 
                        const parseLocal = (d) => {
                            if (!d) return new Date();
                            if (typeof d === 'string' && !d.includes('-06:00') && !d.includes('Z')) {
                                return new Date(d.replace(' ', 'T') + '-06:00');
                            }
                            return new Date(d);
                        };
                        const txDate = parseLocal(tx.fecha_hora);
                    %>
                    <tr data-date="<%= txDate.toLocaleDateString('en-CA', { timeZone: 'America/Tegucigalpa' }) %>" data-tipo="<%= tx.tipo %>">
                        <td>
                            <div style="font-weight: 600; font-size: 0.9rem;"><%= txDate.toLocaleDateString('es-HN', { timeZone: 'America/Tegucigalpa' }) %></div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);"><%= txDate.toLocaleTimeString('es-HN', { timeZone: 'America/Tegucigalpa', hour: '2-digit', minute: '2-digit' }) %></div>
                        </td>
                        <td style="font-weight: 600;"><%= tx.tienda_nombre %></td>
                        <td style="color: #aaa;"><%= tx.username %></td>
                        <td style="font-weight: 700; color: #fff;"><%= tx.banco_nombre || '---' %></td>
                        <td><span class="type-badge <%= cls %>"><%= tx.tipo %></span></td>
                        <td style="font-weight: 700; color: <%= tx.monto_efectivo > 0 ? '#34c759' : (tx.monto_efectivo < 0 ? '#ff453a' : '#888') %>"><%= tx.monto_efectivo > 0 ? '+' : '' %><%= tx.monto_efectivo.toFixed(2) %></td>
                        <td style="font-weight: 700; color: <%= tx.monto_banco > 0 ? '#34c759' : (tx.monto_banco < 0 ? '#ff453a' : '#888') %>"><%= tx.monto_banco > 0 ? '+' : '' %><%= tx.monto_banco.toFixed(2) %></td>
                        <td style="color: #ccc; max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= tx.referencia %>"><%= tx.referencia || '-' %></td>
                        <% if(user.rol !== 'Cajero') { %>
                        <td style="text-align: right;">
                            <div style="display: flex; gap: 0.4rem; justify-content: flex-end;">
                                <button class="btn-action btn-edit" onclick="openEditModal('<%= tx.id %>', '<%= Math.abs(Math.abs(tx.monto_efectivo) - Math.abs(tx.comision_efectivo || 0)) %>', '<%= tx.referencia %>')" title="Editar">✎</button>
                                <form action="/transacciones/eliminar/<%= tx.id %>" method="POST" style="display:inline;" onsubmit="return confirm('¿Está SEGURO de eliminar esta transacción? Los saldos se revertirán automáticamente.')">
                                    <button type="submit" class="btn-action btn-delete" title="Eliminar">🗑</button>
                                </form>
                            </div>
                        </td>
                        <% } %>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Modal Editar -->
    <div id="editModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <span>Editar Transacción</span>
                <span class="close-modal" onclick="closeEditModal()">&times;</span>
            </div>
            <form id="editForm" method="POST">
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">Monto Original</label>
                    <input type="text" name="monto" id="editMonto" class="filter-control money-input" style="width: 100%; padding: 0.8rem;" required>
                </div>
                <div style="margin-bottom: 2rem;">
                    <label style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">Referencia / Descripción</label>
                    <input type="text" name="referencia" id="editRef" class="filter-control" style="width: 100%; padding: 0.8rem;">
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="button" onclick="closeEditModal()" class="filter-control" style="flex: 1; cursor: pointer;">Cancelar</button>
                    <button type="submit" class="filter-control" style="flex: 1; background: var(--accent-blue); border: none; font-weight: 700; cursor: pointer;">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/money-formatter.js"></script>
    <script>
        function openEditModal(id, monto, ref) {
            document.getElementById('editForm').action = '/transacciones/editar/' + id;
            document.getElementById('editMonto').value = parseFloat(monto).toFixed(2);
            document.getElementById('editRef').value = ref === '-' ? '' : ref;
            document.getElementById('editModal').style.display = 'block';
            if(window.formatMoneyInputs) window.formatMoneyInputs(); 
        }

        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
        }

        window.onclick = function(event) {
            if (event.target == document.getElementById('editModal')) closeEditModal();
        }

        document.addEventListener('DOMContentLoaded', () => {
            const dateInput = document.getElementById('filt-fecha');
            // Cargar fecha actual por defecto en zona horaria de Honduras
            const today = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Tegucigalpa' }).format(new Date());
            dateInput.value = today;

            document.querySelectorAll('.filter-control').forEach(el => {
                el.addEventListener('change', filterTable);
                el.addEventListener('input', filterTable);
            });

            filterTable(); // Aplicar el filtro inmediatamente
        });

        function aplicarFiltroTipo(tipo) {
            // El filtro de tipo es server-side: recarga la página con el param
            const url = new URL(window.location.href);
            if (tipo) url.searchParams.set('tipo', tipo);
            else url.searchParams.delete('tipo');
            window.location.href = url.toString();
        }

        function filterTable() {
            const tienda = document.getElementById('filt-tienda') ? document.getElementById('filt-tienda').value.toLowerCase() : '';
            const banco = document.getElementById('filt-banco').value.toLowerCase();
            const fecha = document.getElementById('filt-fecha').value;

            const rows = document.querySelectorAll('#txTable tbody tr');
            rows.forEach(row => {
                const rowDateFormatted = row.getAttribute('data-date');
                const rowTienda = row.cells[1].innerText.toLowerCase();
                const rowBanco = row.cells[3].innerText.toLowerCase();

                const matchTienda = tienda === '' || rowTienda.includes(tienda);
                const matchBanco = banco === '' || rowBanco.includes(banco);
                const matchFecha = fecha === '' || rowDateFormatted === fecha;

                if (matchTienda && matchBanco && matchFecha) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>
